<!DOCTYPE html>
<html>
<head>
<title>Admin Dashboard - Topics</title>
<link rel="stylesheet" href="/css/adminStyle.css">

<style>
/* ================= PAGE LAYOUT ================= */

.topic-wrapper{
    background:#f4f6f9;
    padding:30px;
    border-radius:10px;
}

.page-header{
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

/*.page-header {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 20px;
    color: #2c3e50;
}*/

.page-header h2{
    margin:0;
    font-size:22px;
    font-weight:600;
    color:#2c3e50;
}


/* ================= TABLE CARD ================= */

.table-card{
    background:#fff;
    border-radius:10px;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
    overflow-x:auto;
}


/* ================= TABLE ================= */

table{
    width:100%;
    border-collapse:collapse;
    table-layout:fixed;
}


/* ================= HEADER ================= */

.header-row th{
    background:#2c3e50;
    color:#fff;
    font-size:13px;
    font-weight:600;
    padding:10px 8px;
    text-align:left;
}

.filter-row th{
    background:#2c3e50;
    padding:6px;
}


/* ================= CELLS ================= */

td{
    padding:10px 8px;
    font-size:13px;
    border-bottom:1px solid #e9ecef;
    word-break:break-word;
}

.center{
    text-align:center;
}


/* ================= ROW STYLING ================= */

tbody tr:nth-child(even){
    background:#fafbfd;
}

tbody tr:hover{
    background:#f4f9ff;
}


/* ================= INPUTS ================= */

input[type="text"],
select{
    width:100%;
    padding:6px 8px;
    border:1px solid #d6d6d6;
    border-radius:4px;
    font-size:13px;
    box-sizing:border-box;
}

.filter-row select{
    padding:4px;
    font-size:12px;
}


/* ================= BUTTONS ================= */

button{
    padding:6px 10px;
    border:none;
    border-radius:5px;
    font-size:12px;
    cursor:pointer;
    transition:all .15s ease;
}

button:hover{
    transform:translateY(-1px);
}

/* button colors */

.edit-btn{ background:#3498db; color:white; }

.save-btn{ background:#27ae60; color:white; }

.cancel-btn{ background:#7f8c8d; color:white; }

.delete-btn{ background:#e74c3c; color:white; }

.add-btn{ background:#16a085; color:white; }


/* ================= SORT BUTTON ================= */

.sort-btn{
    background:#34495e;
    color:white;
    font-size:10px;
    padding:2px 6px;
    border-radius:3px;
    margin-left:4px;
}


/* ================= ACTION BUTTONS ================= */

.action-buttons{
    justify-content:center;
    align-items:center;
    gap:6px;
}


/* ================= ADD ROW ================= */

.add-row{
    background:#eef7ff;
}

.add-row td{
    border-top:2px dashed #d6eaff;
}


/* ================= CODE COLUMN ALIGNMENT ================= */

td:nth-child(2),
td:nth-child(4),
td:nth-child(6),
td:nth-child(8){
    text-align:center;
    font-weight:600;
    letter-spacing:1px;
}


/* ================= COLUMN WIDTHS ================= */

th:nth-child(1){width:30px;}

th:nth-child(2){width:75px;}
th:nth-child(3){width:120px;}

th:nth-child(4){width:75px;}
th:nth-child(5){width:120px;}

th:nth-child(6){width:75px;}
th:nth-child(7){width:200px;}

th:nth-child(8){width:75px;}
th:nth-child(9){width:200px;}

th:nth-child(10){width:90px;}

th:nth-child(11){width:190px;}
</style>
</head>

<body>

<%- include('../../../../partials/admin/header') %>

<div class="admin-container">

<%- include('../../../../partials/admin/sidebar') %>

<main class="admin-content">

<div class="topic-wrapper">

<div class="page-header">
<h2>📝 Topic Management</h2>
</div>

<div class="table-card">

<table>

<thead>

<!-- HEADER ROW -->
<tr class="header-row">

<th>#</th>

<th>Exam Code <button class="sort-btn" onclick="sortTable(1)">⇅</button></th>

<th>Exam Name <button class="sort-btn" onclick="sortTable(2)">⇅</button></th>

<th>Subject Code <button class="sort-btn" onclick="sortTable(3)">⇅</button></th>

<th>Subject Name <button class="sort-btn" onclick="sortTable(4)">⇅</button></th>

<th>Unit Code <button class="sort-btn" onclick="sortTable(5)">⇅</button></th>

<th>Unit Name <button class="sort-btn" onclick="sortTable(6)">⇅</button></th>

<th>Topic Code <button class="sort-btn" onclick="sortTable(7)">⇅</button></th>

<th>Topic Name <button class="sort-btn" onclick="sortTable(8)">⇅</button></th>

<th>Created <button class="sort-btn" onclick="sortTable(9)">⇅</button></th>

<th class="center">Actions</th>

</tr>

<!-- FILTER ROW -->

<tr class="filter-row">

<th></th>

<th><select id="filterExamCode" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterExamName" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterSubjectCode" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterSubjectName" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterUnitCode" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterUnitName" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterTopicCode" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterTopicName" onchange="applyFilters()"><option value="">All</option></select></th>

<th><select id="filterCreated" onchange="applyFilters()"><option value="">All</option></select></th>

<th></th>

</tr>

</thead>



<tbody id="topicTableBody">

<% topics.forEach((topic,index)=>{ %>

<tr data-id="<%= topic._id %>">

<td class="center row-number"><%= index+1 %></td>

<td><%= topic.exam?.examcode %></td>
<td><%= topic.exam?.examname %></td>

<td><%= topic.subject?.subjectcode %></td>
<td><%= topic.subject?.subjectname %></td>

<td><%= topic.unit?.unitcode %></td>
<td><%= topic.unit?.unitname %></td>

<td><%= topic.topiccode %></td>

<td class="topicname"><%= topic.topicname %></td>

<td><%= new Date(topic.createdAt).toLocaleDateString() %></td>

<td class="center action-buttons">

<button class="edit-btn" onclick="enableEdit(this)">Edit</button>

<button class="save-btn" style="display:none;" onclick="saveTopic(this)">Save</button>

<button class="cancel-btn" style="display:none;" onclick="cancelEdit(this)">Cancel</button>

<button class="delete-btn" onclick="deleteTopic(this,'<%= topic._id %>')">Delete</button>

</td>

</tr>

<% }) %>

<!-- INLINE ADD ROW -->

<tr id="insertRow" class="add-row">

<td class="center">+</td>

<td id="newExamCode"></td>

<td>

<select id="examSelect" onchange="examChanged()">

<option value="">Select Exam</option>

<% exams.forEach(exam=>{ %>

<option value="<%= exam._id %>" data-code="<%= exam.examcode %>">

<%= exam.examname %>

</option>

<% }) %>

</select>

</td>

<td id="newSubjectCode"></td>

<td>

<select id="subjectSelect" onchange="subjectChanged()">

<option value="">Select Subject</option>

</select>

</td>

<td id="newUnitCode"></td>

<td>

<select id="unitSelect" onchange="unitChanged()">

<option value="">Select Unit</option>

</select>

</td>

<td>

<input id="topicCodeInput" placeholder="Topic Code">

</td>

<td>

<input id="topicNameInput" placeholder="Topic Name">

</td>

<td>--</td>

<td class="center">

<button class="add-btn" onclick="insertTopic()">Add</button>

</td>

</tr>

</tbody>

</table>

</div>

</div>

</main>

</div>

<%- include('../../../../partials/admin/footer') %>

<script>

const subjects = <%- JSON.stringify(subjects) %>;
const units = <%- JSON.stringify(units) %>;

let sortDirection={};

function refreshRowNumbers(){

const rows=document.querySelectorAll("#topicTableBody tr");

let i=1;

rows.forEach(row=>{

if(row.style.display!=="none" && row.id!=="insertRow"){

row.querySelector(".row-number").innerText=i++;

}

});

}

function rebuildFilters(){

const rows=document.querySelectorAll("#topicTableBody tr:not(#insertRow)");

const sets=[new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set()];

rows.forEach(row=>{

for(let i=1;i<=9;i++){

sets[i-1].add(row.children[i].innerText.trim());

}

});

fillDropdown("filterExamCode",sets[0]);
fillDropdown("filterExamName",sets[1]);
fillDropdown("filterSubjectCode",sets[2]);
fillDropdown("filterSubjectName",sets[3]);
fillDropdown("filterUnitCode",sets[4]);
fillDropdown("filterUnitName",sets[5]);
fillDropdown("filterTopicCode",sets[6]);
fillDropdown("filterTopicName",sets[7]);
fillDropdown("filterCreated",sets[8]);

}

function fillDropdown(id,set){

const select=document.getElementById(id);

const current=select.value;

select.innerHTML='<option value="">All</option>';

Array.from(set).sort().forEach(v=>{

const opt=document.createElement("option");

opt.value=v;

opt.textContent=v;

select.appendChild(opt);

});

select.value=current;

}

function applyFilters(){

const filters=[

filterExamCode.value,
filterExamName.value,
filterSubjectCode.value,
filterSubjectName.value,
filterUnitCode.value,
filterUnitName.value,
filterTopicCode.value,
filterTopicName.value,
filterCreated.value

];

const rows=document.querySelectorAll("#topicTableBody tr:not(#insertRow)");

rows.forEach(row=>{

let visible=true;

filters.forEach((f,i)=>{

if(f && row.children[i+1].innerText!==f) visible=false;

});

row.style.display=visible?"":"none";

});

refreshRowNumbers();

}

function sortTable(col){

const table=document.getElementById("topicTableBody");

const rows=Array.from(table.querySelectorAll("tr")).filter(r=>r.id!=="insertRow");

sortDirection[col]=!sortDirection[col];

rows.sort((a,b)=>{

let A=a.children[col].innerText.toLowerCase();

let B=b.children[col].innerText.toLowerCase();

if(A<B) return sortDirection[col]?-1:1;

if(A>B) return sortDirection[col]?1:-1;

return 0;

});

rows.forEach(r=>table.appendChild(r));

table.appendChild(document.getElementById("insertRow"));

refreshRowNumbers();
rebuildFilters();

}

// ---------- Cascading Dropdowns ----------

function examChanged(){

const exam=document.getElementById("examSelect");

const code=exam.selectedOptions[0]?.dataset.code;

document.getElementById("newExamCode").innerText=code||"";

const subjectSelect=document.getElementById("subjectSelect");

subjectSelect.innerHTML='<option value="">Select Subject</option>';

subjects.forEach(s=>{

if(s.exam._id===exam.value){

const opt=document.createElement("option");

opt.value=s._id;

opt.dataset.code=s.subjectcode;

opt.textContent=s.subjectname;

subjectSelect.appendChild(opt);

}

});

subjectChanged();

}

function subjectChanged(){

const sub=document.getElementById("subjectSelect");

const code=sub.selectedOptions[0]?.dataset.code;

document.getElementById("newSubjectCode").innerText=code||"";

const unitSelect=document.getElementById("unitSelect");

unitSelect.innerHTML='<option value="">Select Unit</option>';

units.forEach(u=>{

if(u.subject._id===sub.value){

const opt=document.createElement("option");

opt.value=u._id;

opt.dataset.code=u.unitcode;

opt.textContent=u.unitname;

unitSelect.appendChild(opt);

}

});

unitChanged();

}

function unitChanged(){

const u=document.getElementById("unitSelect");

const code=u.selectedOptions[0]?.dataset.code;

document.getElementById("newUnitCode").innerText=code||"";

}

// ---------- ADD TOPIC ----------

async function insertTopic(){

const examSelect=document.getElementById("examSelect");

const examOpt=examSelect.options[examSelect.selectedIndex];

const examId=examOpt.value, examCode=examOpt.dataset.code;

const subSelect=document.getElementById("subjectSelect");

const subOpt=subSelect.options[subSelect.selectedIndex];

const subId=subOpt.value, subCode=subOpt.dataset.code;

const unitSelectEl=document.getElementById("unitSelect");

const unitOpt=unitSelectEl.options[unitSelectEl.selectedIndex];

const unitId=unitOpt.value, unitCode=unitOpt.dataset.code;

const topiccode=document.getElementById("topicCodeInput").value.trim();

const topicname=document.getElementById("topicNameInput").value.trim();

if(!examId || !subId || !unitId || !topiccode || !topicname){

alert("All fields are required");

return;

}

const res=await fetch("/admin/topics/create",{

method:"POST",

headers:{"Content-Type":"application/json"},

body:JSON.stringify({examId,subId,unitId,examCode,subCode,unitCode,topiccode,topicname})

});

const data=await res.json();

if(data.success){

const tbody=document.getElementById("topicTableBody");

const row=document.createElement("tr");

row.dataset.id=data.topic._id;

row.innerHTML=`

<td class="center row-number"></td>

<td>${examCode}</td>

<td>${examOpt.textContent}</td>

<td>${subCode}</td>

<td>${subOpt.textContent}</td>

<td>${unitCode}</td>

<td>${unitOpt.textContent}</td>

<td>${topiccode}</td>

<td class="topicname">${topicname}</td>

<td>${new Date().toLocaleDateString()}</td>

<td class="center action-buttons">

<button class="edit-btn" onclick="enableEdit(this)">Edit</button>

<button class="save-btn" style="display:none;" onclick="saveTopic(this)">Save</button>

<button class="cancel-btn" style="display:none;" onclick="cancelEdit(this)">Cancel</button>

<button class="delete-btn" onclick="deleteTopic(this,'${data.topic._id}')">Delete</button>

</td>

`;

const insertRow=document.getElementById("insertRow");

tbody.insertBefore(row,insertRow);

document.getElementById("topicCodeInput").value="";

document.getElementById("topicNameInput").value="";

rebuildFilters();

refreshRowNumbers();

}

}

// ---------- EDIT ----------

function enableEdit(btn){

const row=btn.closest("tr");

const cell=row.querySelector(".topicname");

const oldVal=cell.innerText.trim();

cell.innerHTML=`<input class="edit-input" value="${oldVal}">`;

row.querySelector(".edit-btn").style.display="none";

row.querySelector(".save-btn").style.display="inline";

row.querySelector(".cancel-btn").style.display="inline";

row.querySelector(".edit-input").focus();

}

function cancelEdit(btn){

const row=btn.closest("tr");

const cell=row.querySelector(".topicname");

const input=row.querySelector(".edit-input");

cell.innerText=input.defaultValue;

row.querySelector(".edit-btn").style.display="inline";

row.querySelector(".delete-btn").style.display="inline";

row.querySelector(".save-btn").style.display="none";

row.querySelector(".cancel-btn").style.display="none";

}

async function saveTopic(btn){

const row=btn.closest("tr");

const id=row.dataset.id;

const input=row.querySelector(".edit-input");

const newVal=input.value.trim();

if(!newVal){

alert("Topic name cannot be empty");

return;

}

const res=await fetch(`/admin/topics/update/${id}`,{

method:"POST",

headers:{"Content-Type":"application/json"},

body:JSON.stringify({topicname:newVal})

});

const data=await res.json();

if(data.success){

row.querySelector(".topicname").innerText=newVal;

row.querySelector(".edit-btn").style.display="inline";

row.querySelector(".delete-btn").style.display="inline";

row.querySelector(".save-btn").style.display="none";

row.querySelector(".cancel-btn").style.display="none";

rebuildFilters();

}

}

// ---------- DELETE ----------

async function deleteTopic(btn,id){

if(!confirm("Delete this topic?")) return;

const res = await fetch("/admin/topics/delete",{

method:"POST",

headers:{"Content-Type":"application/json"},

body: JSON.stringify({id})

});

const data = await res.json();

if(data.success){

btn.closest("tr").remove();

rebuildFilters();

refreshRowNumbers();

}

}

document.addEventListener("DOMContentLoaded",()=>{

rebuildFilters();

refreshRowNumbers();

});

</script>

</body>

</html>