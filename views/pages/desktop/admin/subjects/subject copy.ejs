<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Subject Management</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>
        body {
            font-family: Arial;
            background: #f4f6f9;
            padding: 30px;
        }

        h2 {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #fff;
        }

        th,
        td {
            padding: 12px;
            border: 1px solid #e0e0e0;
            text-align: left;
        }

        th {
            background: #2c3e50;
            color: #fff;
            cursor: pointer;
        }

        tr:nth-child(even) {
            background: #f9fafc;
        }

        input,
        select {
            padding: 6px;
            width: 90%;
        }

        button {
            padding: 6px 10px;
            border: none;
            cursor: pointer;
            font-size: 13px;
            border-radius: 4px;
        }

        .edit-btn {
            background: #3498db;
            color: #fff;
        }

        .save-btn {
            background: #2ecc71;
            color: #fff;
        }

        .cancel-btn {
            background: #7f8c8d;
            color: #fff;
        }

        .delete-btn {
            background: #e74c3c;
            color: #fff;
        }

        .add-btn {
            background: #27ae60;
            color: #fff;
        }

        .add-row {
            background: #eef7ff;
        }

        .center {
            text-align: center;
        }

        .filter-row {
            background: #ecf0f1;
        }
    </style>
</head>

<body>

    <h2>Subject Management</h2>

    <table>

        <thead>

            <tr>
                <th>#</th>
                <th onclick="sortTable(1)">Exam</th>
                <th onclick="sortTable(2)">Subject Name</th>
                <th onclick="sortTable(3)">Created</th>
                <th>Actions</th>
            </tr>

            <tr class="filter-row">

                <td></td>

                <td>
                    <select id="examFilter" onchange="filterTable()">
                        <option value="">All Exams</option>
                    </select>
                </td>

                <td>
                    <select id="subjectFilter" onchange="filterTable()">
                        <option value="">All Subjects</option>
                    </select>
                </td>

                <td>
                    <select id="dateFilter" onchange="filterTable()">
                        <option value="">All Dates</option>
                    </select>
                </td>

                <td></td>

            </tr>

        </thead>

        <tbody id="subjectTableBody">

            <% subjects.forEach((subject,index)=>{ %>

                <tr id="row-<%= subject._id %>">

                    <td class="center row-number">
                        <%= index+1 %>
                    </td>

                    <td class="exam-col">
                        <%= subject.exam.examname %>
                    </td>

                    <td>

                        <span class="text-<%=subject._id%>">
                            <%=subject.subjectname%>
                        </span>

                        <input type="text" value="<%=subject.subjectname%>" class="input-<%=subject._id%>"
                            style="display:none">

                    </td>

                    <td class="date-col">
                        <%= new Date(subject.createdAt).toLocaleDateString() %>
                    </td>

                    <td>

                        <button class="edit-btn" onclick="enableEdit('<%=subject._id%>')">Edit</button>

                        <button class="save-btn" style="display:none"
                            onclick="saveEdit('<%=subject._id%>')">Save</button>

                        <button class="cancel-btn" style="display:none"
                            onclick="cancelEdit('<%=subject._id%>')">Cancel</button>

                        <button class="delete-btn" onclick="deleteSubject('<%=subject._id%>')">Delete</button>

                    </td>

                </tr>

                <% }) %>

                    <tr class="add-row" id="addRow">

                        <td class="center">+</td>

                        <td>

                            <select id="newExam">

                                <option value="">Select Exam</option>

                                <% exams.forEach(exam=>{ %>

                                    <option value="<%=exam._id%>">
                                        <%=exam.examname%>
                                    </option>

                                    <% }) %>

                            </select>

                        </td>

                        <td>
                            <input type="text" id="newSubjectName" placeholder="Subject name">
                        </td>

                        <td>--</td>

                        <td>
                            <button class="add-btn" onclick="addSubject()">Add</button>
                        </td>

                    </tr>

        </tbody>
    </table>

    <script>

        function refreshRowNumbers() {
            const rows = document.querySelectorAll("#subjectTableBody tr:not(.add-row)");
            rows.forEach((row, index) => {
                row.querySelector(".row-number").innerText = index + 1;
            });
        }

        function enableEdit(id) {

            document.querySelector(".text-" + id).style.display = "none";
            document.querySelector(".input-" + id).style.display = "inline";

            const row = document.getElementById("row-" + id);

            row.querySelector(".edit-btn").style.display = "none";
            row.querySelector(".save-btn").style.display = "inline";
            row.querySelector(".cancel-btn").style.display = "inline";
        }

        function cancelEdit(id) {

            document.querySelector(".text-" + id).style.display = "inline";
            document.querySelector(".input-" + id).style.display = "none";

            const row = document.getElementById("row-" + id);

            row.querySelector(".edit-btn").style.display = "inline";
            row.querySelector(".save-btn").style.display = "none";
            row.querySelector(".cancel-btn").style.display = "none";
        }

        function saveEdit(id) {

            const newName = document.querySelector(".input-" + id).value;

            fetch(`/admin/subjects/update/${id}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ subjectname: newName })
            })
                .then(res => res.json())
                .then(data => {

                    if (data.success) {

                        document.querySelector(".text-" + id).innerText = newName;
                        cancelEdit(id);
                        updateFilters();

                    } else {

                        alert("Update failed");

                    }

                });

        }

        function deleteSubject(id) {

            if (!confirm("Delete subject?")) return;

            fetch(`/admin/subjects/delete/${id}`, { method: "POST" })
                .then(() => {

                    document.getElementById("row-" + id).remove();
                    refreshRowNumbers();
                    updateFilters();

                });

        }

        function addSubject() {

            const name = document.getElementById("newSubjectName").value.trim();
            const exam = document.getElementById("newExam").value;

            if (!name || !exam) {

                alert("Select exam and enter subject name");
                return;

            }

            fetch("/admin/subjects/create", {

                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({

                    subjectname: name,
                    exam: exam

                })

            })
                .then(res => res.json())
                .then(data => {

                    if (!data.success) {

                        alert("Failed");
                        return;

                    }

                    location.reload();

                });

        }

        function sortTable(col) {

            const table = document.getElementById("subjectTableBody");
            const rows = [...table.querySelectorAll("tr:not(.add-row)")];

            rows.sort((a, b) => {

                const A = a.children[col].innerText.toLowerCase();
                const B = b.children[col].innerText.toLowerCase();

                return A.localeCompare(B);

            });

            rows.forEach(r => table.appendChild(r));

            refreshRowNumbers();

        }

        function updateFilters() {

            const examSet = new Set();
            const subjectSet = new Set();
            const dateSet = new Set();

            document.querySelectorAll("#subjectTableBody tr:not(.add-row)").forEach(row => {

                examSet.add(row.querySelector(".exam-col").innerText);
                subjectSet.add(row.children[2].innerText);
                dateSet.add(row.querySelector(".date-col").innerText);

            });

            const examFilter = document.getElementById("examFilter");
            const subjectFilter = document.getElementById("subjectFilter");
            const dateFilter = document.getElementById("dateFilter");

            examFilter.innerHTML = '<option value="">All Exams</option>';
            subjectFilter.innerHTML = '<option value="">All Subjects</option>';
            dateFilter.innerHTML = '<option value="">All Dates</option>';

            examSet.forEach(v => examFilter.innerHTML += `<option>${v}</option>`);
            subjectSet.forEach(v => subjectFilter.innerHTML += `<option>${v}</option>`);
            dateSet.forEach(v => dateFilter.innerHTML += `<option>${v}</option>`);

        }

        function filterTable() {

            const exam = document.getElementById("examFilter").value;
            const subject = document.getElementById("subjectFilter").value;
            const date = document.getElementById("dateFilter").value;

            document.querySelectorAll("#subjectTableBody tr:not(.add-row)").forEach(row => {

                const examCol = row.querySelector(".exam-col").innerText;
                const subjectCol = row.children[2].innerText;
                const dateCol = row.querySelector(".date-col").innerText;

                let show = true;

                if (exam && examCol !== exam) show = false;
                if (subject && subjectCol !== subject) show = false;
                if (date && dateCol !== date) show = false;

                row.style.display = show ? "" : "none";

            });

        }

        updateFilters();

    </script>

</body>

</html>