<!DOCTYPE html>
<html>

<head>
<title>Admin Dashboard - Subjects</title>

<link rel="stylesheet" href="/css/adminStyle.css">

<style>

.subject-wrapper{
background:#f4f6f9;
padding:25px;
border-radius:8px;
}

.subject-wrapper h2{
margin-bottom:20px;
}

table{
width:100%;
border-collapse:collapse;
background:#fff;
}

th,td{
padding:10px;
border:1px solid #e0e0e0;
font-size:14px;
text-align:left;
}

th{
background:#2c3e50;
color:white;
}

tr:nth-child(even){
background:#f9fafc;
}

.center{
text-align:center;
}

input[type="text"],select{
padding:6px;
width:95%;
}

button{
padding:5px 8px;
border:none;
border-radius:4px;
font-size:12px;
cursor:pointer;
}

.edit-btn{background:#3498db;color:white;}
.save-btn{background:#2ecc71;color:white;}
.cancel-btn{background:#7f8c8d;color:white;}
.delete-btn{background:#e74c3c;color:white;}
.add-btn{background:#27ae60;color:white;}

.add-row{
background:#eef7ff;
}

.sort-btn{
background:#34495e;
color:white;
font-size:10px;
padding:2px 5px;
}

</style>

</head>

<body>

<%- include('../../../../partials/admin/header') %>

<div class="admin-container">

<%- include('../../../../partials/admin/sidebar') %>

<main class="admin-content">

<div class="subject-wrapper">

<h2>Subject Management</h2>

<table>

<thead>

<tr>

<th>#</th>

<th>
Exam Name
<button class="sort-btn" onclick="sortTable(1)">⇅</button>
<select id="filterExamName" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
Exam Code
<button class="sort-btn" onclick="sortTable(2)">⇅</button>
<select id="filterExamCode" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
Subject Name
<button class="sort-btn" onclick="sortTable(3)">⇅</button>
<select id="filterSubjectName" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
Subject Code
<button class="sort-btn" onclick="sortTable(4)">⇅</button>
<select id="filterSubjectCode" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
Created
<button class="sort-btn" onclick="sortTable(5)">⇅</button>
<select id="filterCreated" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>Actions</th>

</tr>

</thead>

<tbody id="subjectTableBody">

<% subjects.forEach((subject,index)=>{ %>

<tr id="row-<%= subject._id %>">

<td class="center row-number"><%= index+1 %></td>

<td><%= subject.exam?.examname %></td>

<td><%= subject.exam?.examcode %></td>

<td>

<span class="text-<%= subject._id %>">
<%= subject.subjectname %>
</span>

<input type="text"
value="<%= subject.subjectname %>"
class="input-<%= subject._id %>"
style="display:none;">

</td>

<td>
<%= subject.subjectcode %>
</td>

<td>
<%= new Date(subject.createdAt).toLocaleDateString() %>
</td>

<td>

<button class="edit-btn"
onclick="enableEdit('<%= subject._id %>')">
Edit
</button>

<button class="save-btn"
style="display:none;"
onclick="saveEdit('<%= subject._id %>')">
Save
</button>

<button class="cancel-btn"
style="display:none;"
onclick="cancelEdit('<%= subject._id %>')">
Cancel
</button>

<button class="delete-btn"
onclick="deleteSubject('<%= subject._id %>')">
Delete
</button>

</td>

</tr>

<% }) %>

<!-- ADD SUBJECT ROW -->

<tr class="add-row" id="addRow">

<td class="center">+</td>

<td>

<select id="examSelect" onchange="autoLoadExamCode()">

<option value="">Select Exam</option>

<% exams.forEach(exam=>{ %>

<option
value="<%= exam._id %>"
data-code="<%= exam.examcode %>"
data-name="<%= exam.examname %>">

<%= exam.examname %>

</option>

<% }) %>

</select>

</td>

<td>

<input type="text"
id="examCodeAuto"
placeholder="Auto"
readonly>

</td>

<td>

<input type="text"
id="newSubjectName"
placeholder="Subject Name">

</td>

<td>

<input type="text"
id="newSubjectCode"
placeholder="Subject Code">

</td>

<td>--</td>

<td>

<button class="add-btn" onclick="addSubject()">
Add
</button>

</td>

</tr>

</tbody>

</table>

</div>

</main>

</div>

<%- include('../../../../partials/admin/footer') %>

<script>

let sortDirection={};

function refreshRowNumbers(){

const rows=document.querySelectorAll("#subjectTableBody tr:not(.add-row)");

rows.forEach((row,index)=>{
if(row.style.display!=="none")
row.querySelector(".row-number").innerText=index+1;
});

}

function rebuildFilters(){

const rows=document.querySelectorAll("#subjectTableBody tr:not(.add-row)");

const examNames=new Set();
const examCodes=new Set();
const subjectNames=new Set();
const subjectCodes=new Set();
const dates=new Set();

rows.forEach(row=>{

if(row.style.display!=="none"){

examNames.add(row.children[1].innerText.trim());
examCodes.add(row.children[2].innerText.trim());
subjectNames.add(row.children[3].innerText.trim());
subjectCodes.add(row.children[4].innerText.trim());
dates.add(row.children[5].innerText.trim());

}

});

buildDropdown("filterExamName",examNames);
buildDropdown("filterExamCode",examCodes);
buildDropdown("filterSubjectName",subjectNames);
buildDropdown("filterSubjectCode",subjectCodes);
buildDropdown("filterCreated",dates);

}

function buildDropdown(id,values){

const select=document.getElementById(id);
const current=select.value;

select.innerHTML='<option value="">All</option>';

Array.from(values).sort().forEach(val=>{

const option=document.createElement("option");
option.value=val;
option.textContent=val;
select.appendChild(option);

});

select.value=current;

}

function applyFilters(){

const e1=document.getElementById("filterExamName").value;
const e2=document.getElementById("filterExamCode").value;
const s1=document.getElementById("filterSubjectName").value;
const s2=document.getElementById("filterSubjectCode").value;
const d=document.getElementById("filterCreated").value;

const rows=document.querySelectorAll("#subjectTableBody tr:not(.add-row)");

rows.forEach(row=>{

let show=true;

if(e1 && row.children[1].innerText.trim()!=e1) show=false;
if(e2 && row.children[2].innerText.trim()!=e2) show=false;
if(s1 && row.children[3].innerText.trim()!=s1) show=false;
if(s2 && row.children[4].innerText.trim()!=s2) show=false;
if(d && row.children[5].innerText.trim()!=d) show=false;

row.style.display=show?"":"none";

});

refreshRowNumbers();

}

function sortTable(col){

const table=document.getElementById("subjectTableBody");
const rows=Array.from(table.querySelectorAll("tr:not(.add-row)"));

sortDirection[col]=!sortDirection[col];

rows.sort((a,b)=>{

let A=a.children[col].innerText.toLowerCase();
let B=b.children[col].innerText.toLowerCase();

if(!isNaN(Date.parse(A))){
A=new Date(A);
B=new Date(B);
}

if(A<B) return sortDirection[col]?-1:1;
if(A>B) return sortDirection[col]?1:-1;
return 0;

});

rows.forEach(r=>table.insertBefore(r,document.getElementById("addRow")));

refreshRowNumbers();
rebuildFilters();

}

function enableEdit(id){

document.querySelector(".text-"+id).style.display="none";
document.querySelector(".input-"+id).style.display="inline";

const row=document.getElementById("row-"+id);

row.querySelector(".edit-btn").style.display="none";
row.querySelector(".save-btn").style.display="inline";
row.querySelector(".cancel-btn").style.display="inline";

}

function cancelEdit(id){

document.querySelector(".text-"+id).style.display="inline";
document.querySelector(".input-"+id).style.display="none";

const row=document.getElementById("row-"+id);

row.querySelector(".edit-btn").style.display="inline";
row.querySelector(".save-btn").style.display="none";
row.querySelector(".cancel-btn").style.display="none";

}

function saveEdit(id){

const name=document.querySelector(".input-"+id).value.trim();

fetch(`/admin/subjects/update/${id}`,{
method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({subjectname:name})
})
.then(r=>r.json())
.then(data=>{
if(data.success){

document.querySelector(".text-"+id).innerText=name;
cancelEdit(id);
rebuildFilters();

}else alert("Update failed");
});

}

function deleteSubject(id){

if(!confirm("Delete subject?")) return;

fetch(`/admin/subjects/delete/${id}`,{method:"POST"})
.then(()=>{
document.getElementById("row-"+id).remove();
refreshRowNumbers();
rebuildFilters();
});

}

function autoLoadExamCode(){

const select=document.getElementById("examSelect");

const code=select.options[select.selectedIndex].dataset.code;

document.getElementById("examCodeAuto").value=code||"";

}

function addSubject(){

const examId=document.getElementById("examSelect").value;
const examCode=document.getElementById("examCodeAuto").value;
const subjectName=document.getElementById("newSubjectName").value.trim();
const subjectCode=document.getElementById("newSubjectCode").value.trim();

if(!examId||!subjectName||!subjectCode)
return alert("All fields required");

fetch("/admin/subjects/create",{
method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({
examId,
examcode:examCode,
subjectname:subjectName,
subjectcode:subjectCode
})
})
.then(res=>res.json())
.then(data=>{
if(!data.success) return alert(data.message);
location.reload();
});

}

document.addEventListener("DOMContentLoaded",rebuildFilters);

</script>

</body>
</html>