<!DOCTYPE html>
<html>

<head>
    <title>Admin Dashboard - XYZ</title>

    <link rel="stylesheet" href="/css/adminStyle.css">

    <style>
        .exam-wrapper {
            background: #f4f6f9;
            padding: 25px;
            border-radius: 8px;
        }

        .page-header {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #2c3e50;
        }

        .table-card {
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 10px;
            border-bottom: 1px solid #e6e6e6;
            font-size: 14px;
        }

        th {
            background: #2c3e50;
            color: white;
        }

        tr:nth-child(even) {
            background: #fafbfc;
        }

        .center {
            text-align: center;
        }

        input[type="text"] {
            padding: 6px;
            width: 95%;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 13px;
        }

        select {
            margin-top: 5px;
            width: 100%;
            font-size: 12px;
            padding: 4px;
        }

        button {
            padding: 5px 8px;
            border: none;
            cursor: pointer;
            border-radius: 4px;
            font-size: 12px;
        }

        .edit-btn {
            background: #3498db;
            color: white;
        }

        .save-btn {
            background: #2ecc71;
            color: white;
        }

        .cancel-btn {
            background: #7f8c8d;
            color: white;
        }

        .delete-btn {
            background: #e74c3c;
            color: white;
        }

        .add-btn {
            background: #27ae60;
            color: white;
        }

        .sort-btn {
            background: #34495e;
            color: white;
            font-size: 10px;
            padding: 2px 5px;
            margin-left: 5px;
        }

        .add-row {
            background: #eef7ff;
            border-top: 2px dashed #cfe6ff;
        }

        .action-buttons {
            display: flex;
            gap: 6px;
            justify-content: center;
        }
    </style>
</head>

<body>

    <%- include('../../../../partials/admin/header') %>

        <div class="admin-container">

            <%- include('../../../../partials/admin/sidebar') %>

                <main class="admin-content">

                   <div class="user-wrapper">

        <div class="page-header">
            <h2>User Role Management</h2>
        </div>

        <div id="msg"></div>

        <table>
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th>Add Role</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.username %></td>
                        <td><%= user.email %></td>
                        <td>
                            <% user.roles.forEach(role => { %>
                                <span class="role-badge" id="role-<%= user._id %>-<%= role._id %>">
                                    <%= role.role %>
                                    <% if (!((user.username === 'admin' && role.role === 'admin') ||
                                            (role.role === 'student' && user.username !== 'admin'))) { %>
                                        <button class="role-remove" onclick="removeRole('<%= user._id %>', '<%= role._id %>')">✖</button>
                                    <% } %>
                                </span>
                            <% }) %>
                        </td>
                        <td>
                            <select name="role" class="role-select" id="add-role-<%= user._id %>">
                                <% databaseRoles.forEach(dbRole => { %>
                                    <option value="<%= dbRole._id %>"><%= dbRole.role %></option>
                                <% }) %>
                            </select>
                            <button class="btn" onclick="addRole('<%= user._id %>')">Add</button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    </div>

                </main>

        </div>

        <%- include('../../../../partials/admin/footer') %>



        <script>
        const msg = document.getElementById('msg');

        function showMessage(text, type) {
            msg.innerText = text;
            msg.className = type;
            setTimeout(() => msg.innerText = '', 4000);
        }

        async function removeRole(userId, roleId) {
            try {
                const res = await fetch('/admin/users/remove-role', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId, role: roleId })
                });

                const data = await res.json();

                if (data.success) {
                    showMessage(data.msg || 'Role removed successfully', 'success');
                    const badge = document.getElementById(`role-${userId}-${roleId}`);
                    if (badge) badge.remove();
                } else {
                    showMessage(data.msg || 'Failed to remove role', 'error');
                }
            } catch (e) {
                showMessage('Server error!', 'error');
            }
        }

        async function addRole(userId) {
            const select = document.getElementById(`add-role-${userId}`);
            const roleId = select.value;

            try {
                const res = await fetch('/admin/users/add-role', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId, role: roleId })
                });

                const data = await res.json();

                if (data.success) {
                    showMessage(data.msg || 'Role added successfully', 'success');

                    const td = select.parentElement.previousElementSibling;
                    const newBadge = document.createElement('span');
                    newBadge.className = 'role-badge';
                    newBadge.id = `role-${userId}-${roleId}`;
                    const selectedRoleText = select.options[select.selectedIndex].text;

                    newBadge.innerHTML = `${selectedRoleText} <button class="role-remove" onclick="removeRole('${userId}', '${roleId}')">✖</button>`;
                    td.appendChild(newBadge);
                } else {
                    showMessage(data.msg || 'Failed to add role', 'error');
                }
            } catch (e) {
                showMessage('Server error!', 'error');
            }
        }
    </script>
</body>
</html>