<!DOCTYPE html>
<html>
<head>

<title>Admin Dashboard - Users</title>
<link rel="stylesheet" href="/css/adminStyle.css">

<style>

.user-wrapper{
background:#f4f6f9;
padding:25px;
border-radius:10px;
}

.page-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

.page-header h2{
margin:0;
font-size:22px;
color:#2c3e50;
}

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:8px;
overflow:hidden;
}

th,td{
padding:10px 12px;
text-align:left;
border-bottom:1px solid #eee;
}

th{
background:#f1f3f6;
font-weight:600;
}

.role-badge{
display:inline-block;
background:#4f8ef7;
color:white;
padding:3px 8px;
border-radius:4px;
font-size:12px;
margin-right:4px;
}

.role-remove{
color:#e74c3c;
cursor:pointer;
margin-left:5px;
}

.role-select{
padding:6px;
border:1px solid #ccc;
border-radius:4px;
}

.btn{
padding:6px 10px;
border:none;
background:#4f8ef7;
color:white;
border-radius:4px;
cursor:pointer;
}

.btn:hover{
background:#3c74d9;
}

</style>

</head>

<body>

<div class="user-wrapper">

<div class="page-header">
<h2>User Role Management</h2>
</div>

<table>

<thead>
<tr>
<th>Username</th>
<th>Email</th>
<th>Roles</th>
<th>Add Role</th>
</tr>
</thead>

<tbody>

<% users.forEach(user=>{ %>

<tr>

<td><%= user.username %></td>

<td><%= user.email %></td>

<td>

<% user.roles.forEach(role=>{ %>

<span class="role-badge">
<%= role %>

<form action="/admin/users/remove-role" method="POST" style="display:inline">

<input type="hidden" name="userId" value="<%= user._id %>">
<input type="hidden" name="role" value="<%= role %>">

<button type="submit" class="role-remove">✖</button>

</form>

</span>

<% }) %>

</td>

<td>

<form action="/admin/users/add-role" method="POST">

<input type="hidden" name="userId" value="<%= user._id %>">

<select name="role" class="role-select">

<option value="student">student</option>
<option value="teacher">teacher</option>
<option value="admin">admin</option>

</select>

<button class="btn">Add</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>