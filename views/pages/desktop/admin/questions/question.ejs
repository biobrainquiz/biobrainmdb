                }

                async function saveTopic(btn) {

                    const row = btn.closest("tr");

                    const id = row.dataset.id;

                    const input = row.querySelector(".edit-input");

                    const newVal = input.value.trim();

                    if (!newVal) {

                        alert("Topic name cannot be empty");

                        return;

                    }

                    const res = await fetch(`/admin/topics/update/${id}`, {

                        method: "POST",

                        headers: { "Content-Type": "application/json" },

                        body: JSON.stringify({ topicname: newVal })

                    });

                    const data = await res.json();

                    if (data.success) {

                        row.querySelector(".topicname").innerText = newVal;

                        row.querySelector(".edit-btn").style.display = "inline";

                        row.querySelector(".delete-btn").style.display = "inline";

                        row.querySelector(".save-btn").style.display = "none";

                        row.querySelector(".cancel-btn").style.display = "none";

                        rebuildFilters();

                    }

                }

                // ---------- DELETE ----------

                function deleteQuestion(btn, qid) {
                    if (!confirm("Are you sure you want to delete this question?")) return;

                    fetch("/admin/questions/delete", {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ qid })  // send id in body
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                // remove the row from table
                                const row = btn.closest("tr");
                                row.remove();
                                rebuildFilters();
                                refreshRowNumbers();
                                alert("Question deleted successfully!");
                            } else {
                                alert(data.message || "Failed to delete question.");
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            alert("Error deleting question.");
                        });
                }

                // ---------- EDIT QUESTION ----------

                function enableEdit(btn) {

                    const row = btn.closest("tr");

                    // store original values
                    row.dataset.question = row.querySelector(".question").innerText.trim();
                    row.dataset.opt1 = row.querySelector(".opt1").innerText.trim();
                    row.dataset.opt2 = row.querySelector(".opt2").innerText.trim();
                    row.dataset.opt3 = row.querySelector(".opt3").innerText.trim();
                    row.dataset.opt4 = row.querySelector(".opt4").innerText.trim();
                    row.dataset.answer = row.querySelector(".answer").innerText.trim();
                    row.dataset.marks = row.querySelector(".marks").innerText.trim();
                    row.dataset.difficulty = row.querySelector(".difficulty").innerText.trim();

                    // get cells
                    const questionCell = row.querySelector(".question");
                    const opt1Cell = row.querySelector(".opt1");
                    const opt2Cell = row.querySelector(".opt2");
                    const opt3Cell = row.querySelector(".opt3");
                    const opt4Cell = row.querySelector(".opt4");

                    const answerCell = row.querySelector(".answer");
                    const marksCell = row.querySelector(".marks");
                    const difficultyCell = row.querySelector(".difficulty");

                    // old values
                    const question = questionCell.innerText.trim();
                    const opt1 = opt1Cell.innerText.trim();
                    const opt2 = opt2Cell.innerText.trim();
                    const opt3 = opt3Cell.innerText.trim();
                    const opt4 = opt4Cell.innerText.trim();

                    const answer = answerCell.innerText.trim();
                    const marks = marksCell.innerText.trim();
                    const difficulty = difficultyCell.innerText.trim();

                    // convert to inputs
                    questionCell.innerHTML = `<input class="edit-input question-input" value="${question}">`;

                    opt1Cell.innerHTML = `<input class="edit-input opt1-input" value="${opt1}">`;
                    opt2Cell.innerHTML = `<input class="edit-input opt2-input" value="${opt2}">`;
                    opt3Cell.innerHTML = `<input class="edit-input opt3-input" value="${opt3}">`;
                    opt4Cell.innerHTML = `<input class="edit-input opt4-input" value="${opt4}">`;

                    // answer dropdown
                    answerCell.innerHTML = `
<select class="edit-select answer-input">
<option ${answer === "1" ? "selected" : ""}>1</option>
<option ${answer === "2" ? "selected" : ""}>2</option>
<option ${answer === "3" ? "selected" : ""}>3</option>
<option ${answer === "4" ? "selected" : ""}>4</option>
</select>`;

                    // marks dropdown
                    marksCell.innerHTML = `
<select class="edit-select marks-input">
<option ${marks === "1" ? "selected" : ""}>1</option>
<option ${marks === "2" ? "selected" : ""}>2</option>
</select>`;

                    // difficulty dropdown
                    difficultyCell.innerHTML = `
<select class="edit-select difficulty-input">
<option ${difficulty === "easy" ? "selected" : ""}>easy</option>
<option ${difficulty === "hard" ? "selected" : ""}>hard</option>
</select>`;

                    // buttons
                    row.querySelector(".edit-btn").style.display = "none";
                    row.querySelector(".delete-btn").style.display = "inline";
                    row.querySelector(".save-btn").style.display = "inline";
                    row.querySelector(".cancel-btn").style.display = "inline";

                    // focus first input
                    row.querySelector(".question-input").focus();
                }



                function cancelEdit(btn) {

                    const row = btn.closest("tr");
                    row.querySelector(".question").innerText = row.dataset.question;
                    row.querySelector(".opt1").innerText = row.dataset.opt1;
                    row.querySelector(".opt2").innerText = row.dataset.opt2;
                    row.querySelector(".opt3").innerText = row.dataset.opt3;
                    row.querySelector(".opt4").innerText = row.dataset.opt4;
                    row.querySelector(".answer").innerText = row.dataset.answer;
                    row.querySelector(".marks").innerText = row.dataset.marks;
                    row.querySelector(".difficulty").innerText = row.dataset.difficulty;

                    // buttons
                    row.querySelector(".edit-btn").style.display = "inline";
                    row.querySelector(".delete-btn").style.display = "inline";
                    row.querySelector(".save-btn").style.display = "none";
                    row.querySelector(".cancel-btn").style.display = "none";
                }


                // ---------- SAVE QUESTION ----------

                async function saveQuestion(btn) {

                    const row = btn.closest("tr");
                    const id = row.dataset.id;

                    // read edited values
                    const question = row.querySelector(".question-input").value.trim();

                    const opt1 = row.querySelector(".opt1-input").value.trim();
                    const opt2 = row.querySelector(".opt2-input").value.trim();
                    const opt3 = row.querySelector(".opt3-input").value.trim();
                    const opt4 = row.querySelector(".opt4-input").value.trim();

                    const answer = row.querySelector(".answer-input").value;
                    const marks = row.querySelector(".marks-input").value;
                    const difficulty = row.querySelector(".difficulty-input").value;


                    // validation
                    if (!question || !opt1 || !opt2 || !opt3 || !opt4 || !answer || !marks || !difficulty) {
                        alert("All fields must be filled");
                        return;
                    }

                    try {

                        const res = await fetch(`/admin/questions/update/${id}`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                question,
                                opt1,
                                opt2,
                                opt3,
                                opt4,
                                answer,
                                marks,
                                difficulty
                            })
                        });

                        const data = await res.json();

                        if (!data.success) {
                            alert(data.message || "Update failed");
                            return;
                        }

                        // update table cells
                        row.querySelector(".question").innerText = question;

                        row.querySelector(".opt1").innerText = opt1;
                        row.querySelector(".opt2").innerText = opt2;
                        row.querySelector(".opt3").innerText = opt3;
                        row.querySelector(".opt4").innerText = opt4;

                        row.querySelector(".answer").innerText = answer;
                        row.querySelector(".marks").innerText = marks;
                        row.querySelector(".difficulty").innerText = difficulty;


                        // restore buttons
                        row.querySelector(".edit-btn").style.display = "inline";
                        row.querySelector(".delete-btn").style.display = "inline";
                        row.querySelector(".save-btn").style.display = "none";
                        row.querySelector(".cancel-btn").style.display = "none";

                    } catch (err) {

                        console.error("Save Question Error:", err);
                        alert("Server error while updating question");

                    }

                }

                document.addEventListener("DOMContentLoaded", () => {

                    rebuildFilters();

                    refreshRowNumbers();

                });

            </script>

