<!DOCTYPE html>
<html>
<head>
<title>Admin Dashboard - Questions</title>
<link rel="stylesheet" href="/css/adminStyle.css">

<style>

.question-wrapper{
background:#f4f6f9;
padding:25px;
border-radius:8px;
}

.page-header h2{
margin:0;
font-size:22px;
font-weight:600;
color:#2c3e50;
margin-bottom:20px;
}

.table-card{
background:#fff;
border-radius:8px;
overflow:hidden;
box-shadow:0 2px 6px rgba(0,0,0,0.08);
}

table{
width:100%;
border-collapse:collapse;
}

.header-row th{
background:#2c3e50;
color:white;
font-size:14px;
padding:10px;
}

.filter-row th{
background:#2c3e50;
padding:5px;
}

th,td{
padding:10px;
border-bottom:1px solid #e6e6e6;
font-size:14px;
}

.center{text-align:center;}

tbody tr:nth-child(even){
background:#fafbfc;
}

input[type="text"]{
padding:6px;
width:95%;
border:1px solid #ddd;
border-radius:4px;
font-size:13px;
}

select{
margin-top:5px;
width:100%;
font-size:12px;
padding:4px;
}

button{
padding:5px 8px;
border:none;
cursor:pointer;
border-radius:4px;
font-size:12px;
}

.delete-btn{background:#e74c3c;color:white;}
.add-btn{background:#27ae60;color:white;}

.sort-btn{
background:#34495e;
color:white;
font-size:10px;
padding:2px 5px;
margin-left:5px;
}

.column-selector{
margin-bottom:15px;
}

.add-row{
background:#eef7ff;
border-top:2px dashed #cfe6ff;
}

</style>
</head>

<body>

<%- include('../../../../partials/admin/header') %>

<div class="admin-container">

<%- include('../../../../partials/admin/sidebar') %>

<main class="admin-content">

<div class="question-wrapper">

<div class="page-header">
<h2>❓ Question Management</h2>
</div>

<div class="column-selector">
<label><input type="checkbox" checked onchange="toggleColumn(10)">Question</label>
<label><input type="checkbox" checked onchange="toggleColumn(11)">Opt1</label>
<label><input type="checkbox" checked onchange="toggleColumn(12)">Opt2</label>
<label><input type="checkbox" checked onchange="toggleColumn(13)">Opt3</label>
<label><input type="checkbox" checked onchange="toggleColumn(14)">Opt4</label>
</div>

<div class="table-card">

<table id="questionTable">

<thead>

<tr class="header-row">

<th>#</th>

<th>Exam Code <button class="sort-btn" onclick="sortTable(1)">⇅</button></th>
<th>Exam Name <button class="sort-btn" onclick="sortTable(2)">⇅</button></th>

<th>Subject Code <button class="sort-btn" onclick="sortTable(3)">⇅</button></th>
<th>Subject Name <button class="sort-btn" onclick="sortTable(4)">⇅</button></th>

<th>Unit Code <button class="sort-btn" onclick="sortTable(5)">⇅</button></th>
<th>Unit Name <button class="sort-btn" onclick="sortTable(6)">⇅</button></th>

<th>Topic Code <button class="sort-btn" onclick="sortTable(7)">⇅</button></th>
<th>Topic Name <button class="sort-btn" onclick="sortTable(8)">⇅</button></th>

<th>QNo <button class="sort-btn" onclick="sortTable(9)">⇅</button></th>

<th>Question</th>
<th>Opt1</th>
<th>Opt2</th>
<th>Opt3</th>
<th>Opt4</th>

<th>Answer</th>
<th>Difficulty</th>
<th>Marks</th>
<th>Created</th>

<th class="center">Actions</th>

</tr>

<tr class="filter-row">

<th></th>

<th><select></select></th>
<th><select></select></th>

<th><select></select></th>
<th><select></select></th>

<th><select></select></th>
<th><select></select></th>

<th><select></select></th>
<th><select></select></th>

<th><select></select></th>

<th><select></select></th>

<th><select></select></th>
<th><select></select></th>
<th><select></select></th>
<th><select></select></th>

<th><select></select></th>
<th><select></select></th>
<th><select></select></th>
<th><select></select></th>

<th></th>

</tr>

</thead>

<tbody id="questionTableBody">

<% questions.forEach((q,index)=>{ %>

<tr>

<td class="center"><%= index+1 %></td>

<td><%= q.exam.examcode %></td>
<td><%= q.exam.examname %></td>

<td><%= q.subject.subjectcode %></td>
<td><%= q.subject.subjectname %></td>

<td><%= q.unit.unitcode %></td>
<td><%= q.unit.unitname %></td>

<td><%= q.topic.topiccode %></td>
<td><%= q.topic.topicname %></td>

<td><%= q.qno %></td>

<td><%= q.question %></td>

<td><%= q.opt1 %></td>
<td><%= q.opt2 %></td>
<td><%= q.opt3 %></td>
<td><%= q.opt4 %></td>

<td><%= q.answer %></td>
<td><%= q.difficulty_level %></td>
<td><%= q.marks %></td>

<td><%= new Date(q.createdon).toLocaleDateString() %></td>

<td class="center">
<button class="delete-btn" onclick="deleteQuestion(this,'<%= q._id %>')">Delete</button>
</td>

</tr>

<% }) %>

<tr id="insertRow" class="add-row">

<td>+</td>

<td id="newExamCode"></td>

<td>
<select id="examSelect" onchange="examChanged()">
<option value="">Select Exam</option>
<% exams.forEach(exam=>{ %>
<option value="<%= exam._id %>" data-code="<%= exam.examcode %>">
<%= exam.examname %>
</option>
<% }) %>
</select>
</td>

<td id="newSubjectCode"></td>

<td>
<select id="subjectSelect" onchange="subjectChanged()">
<option value="">Select Subject</option>
</select>
</td>

<td id="newUnitCode"></td>

<td>
<select id="unitSelect" onchange="unitChanged()">
<option value="">Select Unit</option>
</select>
</td>

<td id="newTopicCode"></td>

<td>
<select id="topicSelect" onchange="topicChanged()">
<option value="">Select Topic</option>
</select>
</td>

<td><input id="qnoInput" placeholder="Qno"></td>
<td><input id="questionInput" placeholder="Question"></td>
<td><input id="opt1Input" placeholder="Option 1"></td>
<td><input id="opt2Input" placeholder="Option 2"></td>
<td><input id="opt3Input" placeholder="Option 3"></td>
<td><input id="opt4Input" placeholder="Option 4"></td>

<td>
<select id="answerSelect">
<option value="1">1</option>
<option value="2">2</option>
<option value="3">3</option>
<option value="4">4</option>
</select>
</td>

<td>
<select id="difficultySelect">
<option value="easy">easy</option>
<option value="hard">hard</option>
</select>
</td>

<td>
<select id="marksSelect">
<option>1</option>
<option>2</option>
</select>
</td>

<td>--</td>

<td class="center">
<button class="add-btn" onclick="insertQuestion()">Add</button>
</td>

</tr>

</tbody>

</table>

</div>
</div>
</main>
</div>

<%- include('../../../../partials/admin/footer') %>

<script>

const subjects=<%- JSON.stringify(subjects) %>
const units=<%- JSON.stringify(units) %>
const topics=<%- JSON.stringify(topics) %>

/* ---------------- CASCADING DROPDOWNS ---------------- */

function examChanged(){

const exam=document.getElementById("examSelect")
const code=exam.selectedOptions[0]?.dataset.code || ""
document.getElementById("newExamCode").innerText=code

const subjectSelect=document.getElementById("subjectSelect")
subjectSelect.innerHTML='<option value="">Select Subject</option>'

subjects.forEach(s=>{
if(s.exam._id===exam.value){

let o=document.createElement("option")
o.value=s._id
o.dataset.code=s.subjectcode
o.textContent=s.subjectname

subjectSelect.appendChild(o)

}
})

document.getElementById("newSubjectCode").innerText=""
document.getElementById("newUnitCode").innerText=""
document.getElementById("newTopicCode").innerText=""

document.getElementById("unitSelect").innerHTML='<option value="">Select Unit</option>'
document.getElementById("topicSelect").innerHTML='<option value="">Select Topic</option>'

}

function subjectChanged(){

const sub=document.getElementById("subjectSelect")
const code=sub.selectedOptions[0]?.dataset.code || ""

document.getElementById("newSubjectCode").innerText=code

const unitSelect=document.getElementById("unitSelect")
unitSelect.innerHTML='<option value="">Select Unit</option>'

units.forEach(u=>{
if(u.subject._id===sub.value){

let o=document.createElement("option")
o.value=u._id
o.dataset.code=u.unitcode
o.textContent=u.unitname

unitSelect.appendChild(o)

}
})

document.getElementById("newUnitCode").innerText=""
document.getElementById("newTopicCode").innerText=""

document.getElementById("topicSelect").innerHTML='<option value="">Select Topic</option>'

}

function unitChanged(){

const unit=document.getElementById("unitSelect")
const code=unit.selectedOptions[0]?.dataset.code || ""

document.getElementById("newUnitCode").innerText=code

const topicSelect=document.getElementById("topicSelect")
topicSelect.innerHTML='<option value="">Select Topic</option>'

topics.forEach(t=>{
if(t.unit._id===unit.value){

let o=document.createElement("option")
o.value=t._id
o.dataset.code=t.topiccode
o.textContent=t.topicname

topicSelect.appendChild(o)

}
})

document.getElementById("newTopicCode").innerText=""

}

function topicChanged(){

const topic=document.getElementById("topicSelect")
const code=topic.selectedOptions[0]?.dataset.code || ""

document.getElementById("newTopicCode").innerText=code

}

/* ---------------- COLUMN TOGGLE ---------------- */

function toggleColumn(col){

let table=document.getElementById("questionTable")

for(let r of table.rows){

let cell=r.cells[col]

if(cell) cell.style.display=cell.style.display==="none"?"":"none"

}

}

/* ---------------- FILTERING ---------------- */

function filterTable(){

const table=document.getElementById("questionTable")
const filters=table.querySelectorAll(".filter-row select")
const rows=document.querySelectorAll("#questionTableBody tr:not(#insertRow)")

rows.forEach(row=>{

let show=true

filters.forEach((select,i)=>{

if(!select.value) return

const cell=row.cells[i+1]?.innerText.trim()

if(cell!==select.value) show=false

})

row.style.display=show?"":"none"

})

}

function populateFilters(){

const table=document.getElementById("questionTable")

for(let c=1;c<table.rows[0].cells.length;c++){

let values=new Set()

for(let r=2;r<table.rows.length-1;r++){

let val=table.rows[r].cells[c]?.innerText

if(val) values.add(val)

}

let select=table.rows[1].cells[c]?.querySelector("select")

if(select){

select.innerHTML='<option value="">All</option>'

values.forEach(v=>{

let o=document.createElement("option")

o.value=v
o.text=v

select.appendChild(o)

})

select.addEventListener("change",filterTable)

}

}

}

/* ---------------- SORTING ---------------- */

let sortDir={}

function sortTable(col){

const tbody=document.getElementById("questionTableBody")

const rows=[...tbody.querySelectorAll("tr:not(#insertRow)")]

sortDir[col]=!sortDir[col]

rows.sort((a,b)=>{

let A=a.cells[col].innerText.trim()
let B=b.cells[col].innerText.trim()

if(!isNaN(A)&&!isNaN(B)) return sortDir[col]?A-B:B-A

return sortDir[col]
? A.localeCompare(B)
: B.localeCompare(A)

})

rows.forEach(r=>tbody.insertBefore(r,document.getElementById("insertRow")))

}

function deleteQuestion(btn, qid) {
    if (!confirm("Are you sure you want to delete this question?")) return;

    fetch("/admin/questions/delete", { 
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ qid })  // send id in body
    })
    .then(res => res.json())
    .then(data => {
        if(data.success){
            // remove the row from table
            const row = btn.closest("tr");
            row.remove();
            alert("Question deleted successfully!");
        } else {
            alert(data.message || "Failed to delete question.");
        }
    })
    .catch(err => {
        console.error(err);
        alert("Error deleting question.");
    });
}


/*** Insert Question **/

async function insertQuestion(){

const examSelect=document.getElementById("examSelect");
const examOpt=examSelect.options[examSelect.selectedIndex];
const examId=examOpt.value, examCode=examOpt.dataset.code;

const subSelect=document.getElementById("subjectSelect");
const subOpt=subSelect.options[subSelect.selectedIndex];
const subId=subOpt.value, subCode=subOpt.dataset.code;

const unitSelectEl=document.getElementById("unitSelect");
const unitOpt=unitSelectEl.options[unitSelectEl.selectedIndex];
const unitId=unitOpt.value, unitCode=unitOpt.dataset.code;

const topicSelectEl=document.getElementById("topicSelect");
const topicOpt=topicSelectEl.options[topicSelectEl.selectedIndex];
const topicId=topicOpt.value, topicCode=topicOpt.dataset.code;

const qno=document.getElementById("qnoInput").value.trim();
const questiontxt=document.getElementById("questionInput").value.trim();
const opt1=document.getElementById("opt1Input").value.trim();
const opt2=document.getElementById("opt2Input").value.trim();
const opt3=document.getElementById("opt3Input").value.trim();
const opt4=document.getElementById("opt4Input").value.trim();

const answerSelectEl=document.getElementById("answerSelect");
const answerOpt=answerSelectEl.options[answerSelectEl.selectedIndex];
const answer=answerOpt.value;

const difficultySelectEl=document.getElementById("difficultySelect");
const difficultyOpt=difficultySelectEl.options[difficultySelectEl.selectedIndex];
const difficulty=difficultyOpt.value;

const marksSelectEl=document.getElementById("marksSelect");
const marksOpt=marksSelectEl.options[marksSelectEl.selectedIndex];
const marks=marksOpt.value;

if(!examId || !subId || !unitId || !topicId || !examCode || !subCode || !unitCode || !topicCode || !qno || !questiontxt || !opt1 ||  !opt2 || !opt3 || !opt4 ||!answer || !difficulty || !marks ){

alert("All fields are required");

return;

}

const res=await fetch("/admin/questions/create",{

method:"POST",

headers:{"Content-Type":"application/json"},

body:JSON.stringify({examId, subId, unitId,topicId, examCode, subCode, unitCode, topicCode, qno,question:questiontxt,opt1,opt2,opt3,opt4,answer,difficulty,marks })

});

const data=await res.json();

if(data.success){

const tbody=document.getElementById("questionTableBody");

const row=document.createElement("tr");

row.dataset.id=data.question._id;

row.innerHTML=`

<td class="center row-number"></td>

<td>${examCode}</td>

<td>${examOpt.textContent}</td>

<td>${subCode}</td>

<td>${subOpt.textContent}</td>

<td>${unitCode}</td>

<td>${unitOpt.textContent}</td>

<td>${topicCode}</td>

<td>${topicOpt.textContent}</td>

<td>${qno}</td>
<td>${questiontxt}</td>
<td>${opt1}</td>
<td>${opt2}</td>
<td>${opt3}</td>
<td>${opt4}</td>
<td>${answer}</td>
<td>${difficulty}</td>
<td>${marks}</td>
<td>${new Date().toLocaleDateString()}</td>

<td class="center action-buttons">

<button class="edit-btn" onclick="enableEdit(this)">Edit</button>

<button class="save-btn" style="display:none;" onclick="saveTopic(this)">Save</button>

<button class="cancel-btn" style="display:none;" onclick="cancelEdit(this)">Cancel</button>

<button class="delete-btn" onclick="deleteTopic(this,'${data.question._id}')">Delete</button>

</td>

`;

const insertRow=document.getElementById("insertRow");

tbody.insertBefore(row,insertRow);

/*document.getElementById("questionCodeInput").value="";

document.getElementById("questionNameInput").value="";

rebuildFilters();

refreshRowNumbers();*/

}

}



function refreshRowNumbers(){

const rows=document.querySelectorAll("#questionTableBody tr");

let i=1;

rows.forEach(row=>{

if(row.style.display!=="none" && row.id!=="insertRow"){

row.querySelector(".row-number").innerText=i++;

}

});

}

function rebuildFilters(){

const rows=document.querySelectorAll("#questionTableBody tr:not(#insertRow)");

const sets=[new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set()];

rows.forEach(row=>{

for(let i=1;i<=18;i++){

sets[i-1].add(row.children[i].innerText.trim());

}

});

fillDropdown("filterExamCode",sets[0]);
fillDropdown("filterExamName",sets[1]);
fillDropdown("filterSubjectCode",sets[2]);
fillDropdown("filterSubjectName",sets[3]);
fillDropdown("filterUnitCode",sets[4]);
fillDropdown("filterUnitName",sets[5]);
fillDropdown("filterTopicCode",sets[6]);
fillDropdown("filterTopicName",sets[7]);
fillDropdown("filterCreated",sets[8]);


fillDropdown("filterExamCode",sets[9]);
fillDropdown("filterExamName",sets[10]);
fillDropdown("filterSubjectCode",sets[11]);
fillDropdown("filterSubjectName",sets[12]);
fillDropdown("filterUnitCode",sets[13]);
fillDropdown("filterUnitName",sets[14]);
fillDropdown("filterTopicCode",sets[15]);
fillDropdown("filterTopicName",sets[16]);
fillDropdown("filterCreated",sets[17]);

}
/***********************/

/* ---------------- INIT ---------------- */

populateFilters()

</script>

</body>
</html>