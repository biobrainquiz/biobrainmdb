<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>BioBrain - Prepare Quiz</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/desktopStyle.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            background: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .section {
            padding: 30px 40px;
        }

        /* ===== CARD ===== */
        .card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
            padding: 25px;
            margin-bottom: 25px;

        }

        .card h4 {
            margin-bottom: 18px;
            color: #2c3e50;
        }

        .card-row {
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
        }

        .half-card {
            flex: 1;
            min-width: 350px;
        }

        /* ===== TABLE ===== */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 950px;
            border-collapse: collapse;
            font-size: 14px;
        }

        th {
            background: #2c3e50;
            color: white;
            padding: 10px;
        }

        td {
            padding: 9px;
            border-bottom: 1px solid #eee;
            text-align: center;
        }

        tr:hover {
            background: #f9fbfd;
        }

        .badge-green,
        .badge-red {
            padding: 4px 8px;
            border-radius: 20px;
            font-weight: 600;
        }

        .badge-green {
            background: #e6f9f0;
            color: #1e8449;
        }

        .badge-red {
            background: #fdecea;
            color: #c0392b;
        }

        /* ===== FORM ===== */
        form {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #007bff, #004aad);
            color: white;
            border: none;
            padding: 10px;
            border-radius: 6px;
            cursor: pointer;
            transition: .3s;
        }

        .btn-primary:hover {
            opacity: .9;
        }

        /* ===== INLINE SELECT ROW ===== */
        .inline-row {
            display: flex;
            gap: 15px;
        }

        .inline-group {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .inline-group select {
            padding: 8px 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 13px;
        }

        /* Responsive */
        @media (max-width: 600px) {
            .inline-row {
                flex-direction: column;
            }
        }

        /* ===== CUSTOM DROPDOWN ===== */
        .custom-dropdown {
            position: relative;
            width: 100%;
            cursor: pointer;
        }

        .custom-dropdown.disabled .dropdown-selected {
            background: #f2f2f2;
            cursor: not-allowed;
        }

        .dropdown-selected,
        .dropdown-search,
        .dropdown-option {
            text-align: left;
            font-size: 13px;
        }


        .dropdown-selected {
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            background: #fff;
            transition: .2s;
        }

        .dropdown-selected:hover {
            border-color: #007bff;
        }

        .dropdown-menu {
            position: absolute;
            width: 100%;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            margin-top: 6px;
            max-height: 0;
            overflow: hidden;
            opacity: 0;
            transition: max-height .3s ease, opacity .2s ease;
            z-index: 1000;
        }

        .custom-dropdown.active .dropdown-menu {
            max-height: 300px;
            opacity: 1;
        }

        .dropdown-search {
            width: 100%;
            padding: 8px;
            border: none;
            border-bottom: 1px solid #eee;
            outline: none;
        }

        .dropdown-options {
            max-height: 220px;
            overflow-y: auto;
            padding-bottom: 15px;
            /* prevents bottom touch */
        }

        .dropdown-option {
            padding: 8px 14px;
            transition: .2s;
        }

        .dropdown-option:hover {
            background: #f2f6ff;
        }

        /* ===== PAGINATION ===== */

        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .pagination a,
        .pagination span {
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 14px;
            text-decoration: none;
            border: 1px solid #ddd;
            color: #2c3e50;
            background: #fff;
            transition: 0.2s;
        }

        .pagination a:hover {
            background: #2c3e50;
            color: white;
        }

        .pagination .active {
            background: #2c3e50;
            color: white;
            border-color: #2c3e50;
            pointer-events: none;
        }

        .pagination .disabled {
            opacity: 0.4;
            pointer-events: none;
        }
    </style>
</head>

<body>

    <%- include('../../partials/desktop/header') %>

        <section class="section">
            <!-- card for displaying 50 Past performances-->
            <div class="card">
                <h4>📊 Your Last 50 Quiz Performances</h4>

                <% if (prepareTestObj.pageresult && prepareTestObj.pageresult.length> 0) { %>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Attempt #</th>
                                    <th>Date</th>
                                    <th>Exam</th>
                                    <th>Subject</th>
                                    <th>Unit</th>
                                    <th>Topic</th>
                                    <th>Difficulty</th>
                                    <th>Questions</th>
                                    <th>Attempted</th>
                                    <th>Skipped</th>
                                    <th>Right</th>
                                    <th>Wrong</th>
                                    <th>Accuracy</th>
                                    <th>Percentage</th>
                                </tr>
                            </thead>

                            <tbody>
                                <% prepareTestObj.pageresult.forEach((q,index)=>{ %>
                                    <tr>
                                        <td>
                                            <%= index+1 %>
                                        </td>
                                        <td>
                                            <%= new Date(q.createdAt).toLocaleDateString() %>
                                                <%= new Date(q.createdAt).toLocaleTimeString([], { hour: '2-digit' ,
                                                    minute: '2-digit' }) %>
                                        </td>
                                        <td>
                                            <%= q.examname %>
                                        </td>
                                        <td>
                                            <%= q.subjectname %>
                                        </td>

                                        <!-- Truncated unitName with tooltip -->
                                        <td title="<%= q.unitname %>">
                                            <%= q.unitname.length> 15 ? q.unitname.slice(0,15) + '...' : q.unitname %>
                                        </td>

                                        <!-- Truncated topicName with tooltip -->
                                        <td title="<%= q.topicname %>">
                                            <%= q.topicname.length> 20 ? q.topicname.slice(0,20) + '...' : q.topicname
                                                %>
                                        </td>
                                        <td>
                                            <%= q.difficulty %>
                                        </td>
                                        <td>
                                            <%= q.questionscount %>
                                        </td>
                                        <td>
                                            <%= q.attempted %>
                                        </td>
                                        <td>
                                            <%= q.skipped %>
                                        </td>
                                        <td>
                                            <%= q.right %>
                                        </td>
                                        <td>
                                            <%= q.wrong %>
                                        </td>

                                        <td>
                                            <% if (q.accuracy>= 70) { %>
                                                <span class="badge-green">
                                                    <%= q.accuracy %>%
                                                </span>
                                                <% } else { %>
                                                    <span class="badge-red">
                                                        <%= q.accuracy %>%
                                                    </span>
                                                    <% } %>
                                        </td>

                                        <td>
                                            <% if (q.percentage>= 70) { %>
                                                <span class="badge-green">
                                                    <%= q.percentage %>%
                                                </span>
                                                <% } else { %>
                                                    <span class="badge-red">
                                                        <%= q.percentage %>%
                                                    </span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- ===== PAGINATION CONTROLS ===== -->

                    <div class="pagination">

                        <!-- Previous -->
                        <% if(prepareTestObj.pageno> 1){ %>
                            <a href="?page=<%= prepareTestObj.pageno - 1 %>">⬅ Previous</a>
                            <% } else { %>
                                <span class="disabled">⬅ Previous</span>
                                <% } %>

                                    <!-- Page Numbers -->
                                    <% for(let i=1; i <=prepareTestObj.totalpages; i++){ %>

                                        <% if(i===prepareTestObj.pageno){ %>
                                            <span class="active">
                                                <%= i %>
                                            </span>
                                            <% } else { %>
                                                <a href="?page=<%= i %>">
                                                    <%= i %>
                                                </a>
                                                <% } %>

                                                    <% } %>

                                                        <!-- Next -->
                                                        <% if(prepareTestObj.pageno < prepareTestObj.totalpages){ %>
                                                            <a href="?page=<%= prepareTestObj.pageno + 1 %>">Next ➡</a>
                                                            <% } else { %>
                                                                <span class="disabled">Next ➡</span>
                                                                <% } %>

                    </div>
                    <% } else { %>
                        <p>No quiz attempts found.</p>
                        <% } %>
            </div>

            <div class="card-row">
                <!-- card for configuring Quiz-->
                <div class="card half-card">
                    <h4>⚙ Configure Your Exam</h4>

                    <form action="/mocktest/createorder" method="POST">
                        <input type="hidden" name="examcode" value="<%= prepareTestObj.examcode %>">
                        <input type="hidden" name="subjectcode" value="<%= prepareTestObj.subjectcode %>">

                        <label>Unit</label>
                        <div class="custom-dropdown" id="unitWrapper">
                            <div class="dropdown-selected">Select Unit</div>
                            <div class="dropdown-menu">
                                <input type="text" class="dropdown-search" placeholder="Search unit...">
                                <div class="dropdown-options"></div>
                            </div>
                        </div>
                        <input type="hidden" name="unitcode" id="unitHidden" required>

                        <label>Topic</label>
                        <div class="custom-dropdown disabled" id="topicWrapper">
                            <div class="dropdown-selected">Select Topic</div>
                            <div class="dropdown-menu">
                                <input type="text" class="dropdown-search" placeholder="Search topic...">
                                <div class="dropdown-options"></div>
                            </div>
                        </div>
                        <input type="hidden" name="topiccode" id="topicHidden" required>

                        <div class="inline-row">
                            <div class="inline-group">
                                <label>No. of Questions</label>
                                <select name="count">
                                    <option value="10">10</option>
                                    <option value="20">20</option>
                                    <option value="30">30</option>
                                </select>
                            </div>

                            <div class="inline-group">
                                <label>Difficulty</label>
                                <select name="difficulty">
                                    <option value="easy">Easy</option>
                                    <option value="hard">Hard</option>
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="btn-primary">Proceed to Payment</button>
                        <p id="formError" style="color:red; display:none; font-size:13px;"></p>
                    </form>
                </div>
                <!-- card for Performance Dashboard-->
                <div class="card half-card">
                    <h4>📈 Performance Dashboard</h4>

                    <% if (prepareTestObj.resultsforgraph && prepareTestObj.resultsforgraph.length> 0) { %>
                        <canvas id="performanceChart" height="200"></canvas>
                        <% } else { %>
                            <p>No data available for chart.</p>
                            <% } %>
                </div>
            </div>
        </section>
        <%- include('../../partials/desktop/footer') %>

            <script>
                // Script for validating unit,topic,count,difficulty before submit
                const form = document.querySelector("form");
                form.addEventListener("submit", function (e) {
                    const errorBox = document.getElementById("formError");
                    const unit = document.getElementById("unitHidden").value;
                    const topic = document.getElementById("topicHidden").value;
                    const count = document.querySelector("select[name='count']").value;
                    const difficulty = document.querySelector("select[name='difficulty']").value;

                    if (!unit || !topic || !count || !difficulty) {
                        e.preventDefault();
                        errorBox.style.display = "block";
                        errorBox.textContent = "Please complete all fields before proceeding.";
                        return;
                    }

                    errorBox.style.display = "none";

                });
            </script>

            <script>
                //script for filling unit,topic dropdowns
                const examcode = "<%= prepareTestObj.examcode %>";
                const subjectcode = "<%= prepareTestObj.subjectcode %>";

                function truncate(text, max = 40) {
                    return text.length > max ? text.substring(0, max) + "..." : text;
                }

                function setupDropdown(wrapperId, hiddenInputId) {
                    const wrapper = document.getElementById(wrapperId);
                    const selected = wrapper.querySelector(".dropdown-selected");
                    const optionsContainer = wrapper.querySelector(".dropdown-options");
                    const searchInput = wrapper.querySelector(".dropdown-search");
                    const hiddenInput = document.getElementById(hiddenInputId);

                    selected.addEventListener("click", () => {
                        if (wrapper.classList.contains("disabled")) return;
                        wrapper.classList.toggle("active");
                    });

                    document.addEventListener("click", e => {
                        if (!wrapper.contains(e.target)) {
                            wrapper.classList.remove("active");
                        }
                    });

                    searchInput.addEventListener("input", () => {
                        const filter = searchInput.value.toLowerCase();
                        [...optionsContainer.children].forEach(opt => {
                            opt.style.display = opt.textContent.toLowerCase().includes(filter) ? "block" : "none";
                        });
                    });

                    return {
                        setOptions(data, labelKey, valueKey) {
                            optionsContainer.innerHTML = "";
                            data.forEach(item => {
                                const div = document.createElement("div");
                                div.className = "dropdown-option";
                                div.textContent = truncate(item[labelKey]);
                                div.title = item[labelKey];

                                div.onclick = () => {
                                    selected.textContent = truncate(item[labelKey]);
                                    selected.title = item[labelKey];
                                    hiddenInput.value = item[valueKey];
                                    wrapper.classList.remove("active");
                                };

                                optionsContainer.appendChild(div);
                            });
                        },
                        enable() { wrapper.classList.remove("disabled"); },
                        disable() { wrapper.classList.add("disabled"); }
                    };
                }

                const unitDropdown = setupDropdown("unitWrapper", "unitHidden");
                const topicDropdown = setupDropdown("topicWrapper", "topicHidden");

                window.addEventListener("DOMContentLoaded", async () => {
                    const res = await fetch(`/units/${examcode}/${subjectcode}`);
                    const units = await res.json();
                    unitDropdown.setOptions(units, "unitname", "unitcode");
                });

                document.getElementById("unitWrapper")
                    .querySelector(".dropdown-options")
                    .addEventListener("click", async () => {
                        const unitcode = document.getElementById("unitHidden").value;
                        if (!unitcode) return;

                        topicDropdown.enable();
                        const res = await fetch(`/topics/${examcode}/${subjectcode}/${unitcode}`);
                        const topics = await res.json();
                        topicDropdown.setOptions(topics, "topicname", "topiccode");
                    });
            </script>

            <script>
                // script for displaying graph that renders users performance
                document.addEventListener("DOMContentLoaded", function () {

<% if (prepareTestObj.resultsforgraph && prepareTestObj.resultsforgraph.length > 1) { %>

const accuracyData = [
    <% prepareTestObj.resultsforgraph.forEach(function (q, index) { %>
        <%= q.accuracy %><%= index < prepareTestObj.resultsforgraph.length - 1 ? "," : "" %>
    <% }) %>
];

                        const n = accuracyData.length;
                        const labels = accuracyData.map((_, i) => "Attempt " + (i + 1));
                        const xValues = accuracyData.map((_, i) => i + 1);

                        // =======================
                        // 📊 BASIC STATISTICS
                        // =======================
                        const mean = accuracyData.reduce((a, b) => a + b, 0) / n;

                        const stdDev = Math.sqrt(
                            accuracyData.map(x => Math.pow(x - mean, 2))
                                .reduce((a, b) => a + b, 0) / n
                        );

                        // =======================
                        // 📈 MOVING AVERAGE (5)
                        // =======================
                        const movingAverage = accuracyData.map((_, i, arr) => {
                            const start = Math.max(0, i - 4);
                            const subset = arr.slice(start, i + 1);
                            return subset.reduce((a, b) => a + b, 0) / subset.length;
                        });

                        // =======================
                        // 📊 CUMULATIVE AVERAGE
                        // =======================
                        let cumulativeSum = 0;
                        const cumulativeAvg = accuracyData.map((val, i) => {
                            cumulativeSum += val;
                            return cumulativeSum / (i + 1);
                        });

                        // =======================
                        // 📈 LINEAR REGRESSION
                        // =======================
                        const sumX = xValues.reduce((a, b) => a + b, 0);
                        const sumY = accuracyData.reduce((a, b) => a + b, 0);
                        const sumXY = xValues.reduce((sum, x, i) => sum + x * accuracyData[i], 0);
                        const sumX2 = xValues.reduce((sum, x) => sum + x * x, 0);

                        const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
                        const intercept = (sumY - slope * sumX) / n;

                        let predictedScore = slope * (n + 1) + intercept;
                        predictedScore = Math.max(0, Math.min(100, predictedScore));

                        // Regression line
                        const regressionLine = xValues.map(x => slope * x + intercept);
                        regressionLine.push(predictedScore);
                        labels.push("Predicted");

                        // =======================
                        // ⭐ BEST / WORST
                        // =======================
                        const maxValue = Math.max(...accuracyData);
                        const minValue = Math.min(...accuracyData);
                        const bestIndex = accuracyData.indexOf(maxValue);
                        const worstIndex = accuracyData.indexOf(minValue);

                        const bestPoint = accuracyData.map((v, i) => i === bestIndex ? v : null);
                        const worstPoint = accuracyData.map((v, i) => i === worstIndex ? v : null);

                        // =======================
                        // 🎨 GRADIENT
                        // =======================
                        const ctx = document.getElementById("performanceChart").getContext("2d");
                        const gradient = ctx.createLinearGradient(0, 0, 0, 400);
                        gradient.addColorStop(0, "rgba(0,123,255,0.4)");
                        gradient.addColorStop(1, "rgba(0,123,255,0.05)");

                        new Chart(ctx, {
                            type: "line",
                            data: {
                                labels: labels,
                                datasets: [

                                    // 🔵 Raw Accuracy
                                    {
                                        label: "Accuracy %",
                                        data: accuracyData,
                                        borderColor: "#1f77ff",
                                        backgroundColor: gradient,
                                        tension: 0.4,
                                        fill: true,
                                        borderWidth: 3
                                    },

                                    // 🟢 Cumulative Improvement
                                    {
                                        label: "Cumulative Average",
                                        data: cumulativeAvg,
                                        borderColor: "#00b894",
                                        borderWidth: 2,
                                        tension: 0.4,
                                        fill: false
                                    },

                                    // 🟠 Moving Average
                                    {
                                        label: "Moving Avg (5)",
                                        data: movingAverage,
                                        borderColor: "#ff9f43",
                                        borderDash: [6, 6],
                                        borderWidth: 2,
                                        fill: false
                                    },

                                    // 🟣 Regression Trend
                                    {
                                        label: "Trend Line",
                                        data: regressionLine,
                                        borderColor: "#6c5ce7",
                                        borderDash: [4, 4],
                                        borderWidth: 2,
                                        fill: false,
                                        tension: 0
                                    },

                                    // 🌸 Predicted Point (Deep Pink)
                                    {
                                        label: "Predicted Next Score",
                                        data: [...Array(n).fill(null), predictedScore],
                                        borderColor: "#e84393",
                                        backgroundColor: "#e84393",
                                        pointRadius: 9,
                                        pointHoverRadius: 11,
                                        showLine: false
                                    },

                                    // 🟦 Overall Average (Teal)
                                    {
                                        label: "Overall Average",
                                        data: Array(n + 1).fill(mean),
                                        borderColor: "#00cec9",
                                        borderDash: [3, 3],
                                        borderWidth: 2,
                                        fill: false
                                    },

                                    // 🔺 Mean + 1σ (Soft Crimson)
                                    {
                                        label: "Mean + 1σ(stdDev)",
                                        data: Array(n + 1).fill(mean + stdDev),
                                        borderColor: "#ff6b6b",
                                        borderDash: [2, 2],
                                        borderWidth: 1.5,
                                        fill: false
                                    },

                                    // 🔻 Mean - 1σ (Slate Gray)
                                    {
                                        label: "Mean - 1σ(stdDev)",
                                        data: Array(n + 1).fill(mean - stdDev),
                                        borderColor: "#636e72",
                                        borderDash: [2, 2],
                                        borderWidth: 1.5,
                                        fill: false
                                    },

                                    // 🏆 Best Attempt (Gold)
                                    {
                                        label: "Best Attempt",
                                        data: bestPoint,
                                        borderColor: "#f1c40f",
                                        backgroundColor: "#f1c40f",
                                        pointRadius: 9,
                                        pointHoverRadius: 11,
                                        showLine: false
                                    },

                                    // 🔥 Worst Attempt (Dark Red - Unique)
                                    {
                                        label: "Worst Attempt",
                                        data: worstPoint,
                                        borderColor: "#b71540",
                                        backgroundColor: "#b71540",
                                        pointRadius: 9,
                                        pointHoverRadius: 11,
                                        showLine: false
                                    }

                                ]
                            },
                            options: {
                                responsive: true,
                                animation: {
                                    duration: 1600,
                                    easing: "easeInOutQuart"
                                },
                                plugins: {
                                    legend: { position: "top" },
                                    tooltip: {
                                        callbacks: {
                                            footer: function () {
                                                return "Mean: " + mean.toFixed(2) +
                                                    " | Std Dev: " + stdDev.toFixed(2) +
                                                    " | Predicted: " + predictedScore.toFixed(2) + "%";
                                            }
                                        }
                                    }
                                },
                                scales: {
                                    y: {
                                        min: 0,
                                        max: 100,
                                        title: { display: true, text: "Accuracy (%)" }
                                    },
                                    x: {
                                        title: { display: true, text: "Attempt Number" }
                                    }
                                }
                            }
                        });

<% } %>

});
            </script>
</body>

</html>