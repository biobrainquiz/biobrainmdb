<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>BioBrain - Prepare Quiz</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/desktopStyle.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body {
            background: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .section {
            padding: 30px 40px;
        }

        /* ===== CARD ===== */
        .card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
            padding: 25px;
            margin-bottom: 25px;

        }

        .card h4 {
            margin-bottom: 18px;
            color: #2c3e50;
        }

        .card-row {
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
        }

        .half-card {
            flex: 1;
            min-width: 350px;
        }

        /* ===== TABLE ===== */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 950px;
            border-collapse: collapse;
            font-size: 14px;
        }

        th {
            background: #2c3e50;
            color: white;
            padding: 10px;
        }

        td {
            padding: 9px;
            border-bottom: 1px solid #eee;
            text-align: center;
        }

        tr:hover {
            background: #f9fbfd;
        }

        .badge-green,
        .badge-red {
            padding: 4px 8px;
            border-radius: 20px;
            font-weight: 600;
        }

        .badge-green {
            background: #e6f9f0;
            color: #1e8449;
        }

        .badge-red {
            background: #fdecea;
            color: #c0392b;
        }

        /* ===== FORM ===== */
        form {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #007bff, #004aad);
            color: white;
            border: none;
            padding: 10px;
            border-radius: 6px;
            cursor: pointer;
            transition: .3s;
        }

        .btn-primary:hover {
            opacity: .9;
        }

        /* ===== INLINE SELECT ROW ===== */
        .inline-row {
            display: flex;
            gap: 15px;
        }

        .inline-group {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .inline-group select {
            padding: 8px 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 13px;
        }

        /* Responsive */
        @media (max-width: 600px) {
            .inline-row {
                flex-direction: column;
            }
        }

        /* ===== CUSTOM DROPDOWN ===== */
        .custom-dropdown {
            position: relative;
            width: 100%;
            cursor: pointer;
        }

        .custom-dropdown.disabled .dropdown-selected {
            background: #f2f2f2;
            cursor: not-allowed;
        }

        .dropdown-selected,
        .dropdown-search,
        .dropdown-option {
            text-align: left;
            font-size: 13px;
        }


        .dropdown-selected {
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            background: #fff;
            transition: .2s;
        }

        .dropdown-selected:hover {
            border-color: #007bff;
        }

        .dropdown-menu {
            position: absolute;
            width: 100%;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            margin-top: 6px;
            max-height: 0;
            overflow: hidden;
            opacity: 0;
            transition: max-height .3s ease, opacity .2s ease;
            z-index: 1000;
        }

        .custom-dropdown.active .dropdown-menu {
            max-height: 300px;
            opacity: 1;
        }

        .dropdown-search {
            width: 100%;
            padding: 8px;
            border: none;
            border-bottom: 1px solid #eee;
            outline: none;
        }

        .dropdown-options {
            max-height: 220px;
            overflow-y: auto;
            padding-bottom: 15px;
            /* prevents bottom touch */
        }

        .dropdown-option {
            padding: 8px 14px;
            transition: .2s;
        }

        .dropdown-option:hover {
            background: #f2f6ff;
        }

        /* ===== PAGINATION ===== */

        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .pagination a,
        .pagination span {
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 14px;
            text-decoration: none;
            border: 1px solid #ddd;
            color: #2c3e50;
            background: #fff;
            transition: 0.2s;
        }

        .pagination a:hover {
            background: #2c3e50;
            color: white;
        }

        .pagination .active {
            background: #2c3e50;
            color: white;
            border-color: #2c3e50;
            pointer-events: none;
        }

        .pagination .disabled {
            opacity: 0.4;
            pointer-events: none;
        }



        .performance-dashboard-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            /* centers everything */
            gap: 8px;
            padding: 10px;
        }

        /* label */
        .performance-dashboard-card label {
            font-weight: 600;
            font-size: 14px;
            color: #444;
        }

        /* dropdown medium size */
        .performance-dashboard-card select {
            font-size: 13px;
            border-radius: 6px;
            border: 1px solid #ccc;
            text-align: center;
        }

        /* chart */
        .performance-dashboard-card canvas {
            width: 100% !important;
            max-height: 420px;
        }

        .action-icons {
            display: flex;
            gap: 10px;
            justify-content: center;
            font-size: 18px;
        }

        .action-icons a {
            text-decoration: none;
            cursor: pointer;
            transition: 0.2s;
        }

        .action-icons a:hover {
            transform: scale(1.2);
        }
    </style>
</head>

<body>

    <%- include('../../partials/desktop/header') %>

        <section class="section">
            <!-- card for displaying 50 Past performances-->
            <div class="card">
                <h4>📊 Your Last 50 Quiz Performances</h4>

                <% if (prepareTestObj.pageresult && prepareTestObj.pageresult.length> 0) { %>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <!--<th>Attempt #</th>-->
                                    <th>Date</th>
                                    <th>Exam</th>
                                    <th>Subject</th>
                                    <th>Unit</th>
                                    <th>Topic</th>
                                    <th>Difficulty</th>
                                    <th>Questions</th>
                                    <th>Attempted</th>
                                    <th>Skipped</th>
                                    <th>Right</th>
                                    <th>Wrong</th>
                                    <th>Accuracy</th>
                                    <th>Percentage</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                <% prepareTestObj.pageresult.forEach((r,index)=>{ %>
                                    <tr>
                                        <!--<td>
                                            <%= index+1 %>
                                        </td>-->
                                        <td>
                                            <%= new Date(r.createdAt).toLocaleString('en-GB', { day: '2-digit' ,
                                                month: 'short' , year: 'numeric' , hour: 'numeric' , minute: '2-digit' ,
                                                hour12: true }) %>
                                        </td>
                                        <td>
                                            <%= r.examname %>
                                        </td>
                                        <td>
                                            <%= r.subjectname %>
                                        </td>

                                        <!-- Truncated unitName with tooltip -->
                                        <td title="<%= r.unitname %>">
                                            <%= r.unitname.length> 15 ? r.unitname.slice(0,15) + '...' : r.unitname %>
                                        </td>

                                        <!-- Truncated topicName with tooltip -->
                                        <td title="<%= r.topicname %>">
                                            <%= r.topicname.length> 20 ? r.topicname.slice(0,20) + '...' : r.topicname
                                                %>
                                        </td>
                                        <td>
                                            <%= r.difficulty %>
                                        </td>
                                        <td>
                                            <%= r.questionscount %>
                                        </td>
                                        <td>
                                            <%= r.attempted %>
                                        </td>
                                        <td>
                                            <%= r.skipped %>
                                        </td>
                                        <td>
                                            <%= r.right %>
                                        </td>
                                        <td>
                                            <%= r.wrong %>
                                        </td>

                                        <td>
                                            <% if (r.accuracy>= 70) { %>
                                                <span class="badge-green">
                                                    <%= r.accuracy %>%
                                                </span>
                                                <% } else { %>
                                                    <span class="badge-red">
                                                        <%= r.accuracy %>%
                                                    </span>
                                                    <% } %>
                                        </td>

                                        <td>
                                            <% if (r.percentage>= 70) { %>
                                                <span class="badge-green">
                                                    <%= r.percentage %>%
                                                </span>
                                                <% } else { %>
                                                    <span class="badge-red">
                                                        <%= r.percentage %>%
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td class="action-icons">

                                            <a href="/mocktest/result/pdf/<%= r._id %>" title="Download PDF">
                                                <i class="fa-solid fa-file-pdf"></i>
                                            </a>

                                            <a href="/mocktest/result/email/<%= r._id %>" title="Send Email">
                                                <i class="fa-solid fa-envelope"></i>
                                            </a>

                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- ===== PAGINATION CONTROLS ===== -->

                    <div class="pagination">

                        <!-- Previous -->
                        <% if(prepareTestObj.pageno> 1){ %>
                            <a href="?pageno=<%= prepareTestObj.pageno - 1 %>">⬅ Previous</a>
                            <% } else { %>
                                <span class="disabled">⬅ Previous</span>
                                <% } %>

                                    <!-- Page Numbers -->
                                    <% for(let i=1; i <=prepareTestObj.totalpages; i++){ %>

                                        <% if(i===prepareTestObj.pageno){ %>
                                            <span class="active">
                                                <%= i %>
                                            </span>
                                            <% } else { %>
                                                <a href="?pageno=<%= i %>">
                                                    <%= i %>
                                                </a>
                                                <% } %>

                                                    <% } %>

                                                        <!-- Next -->
                                                        <% if(prepareTestObj.pageno < prepareTestObj.totalpages){ %>
                                                            <a href="?pageno=<%= prepareTestObj.pageno + 1 %>">Next
                                                                ➡</a>
                                                            <% } else { %>
                                                                <span class="disabled">Next ➡</span>
                                                                <% } %>

                    </div>
                    <% } else { %>
                        <p>No quiz attempts found.</p>
                        <% } %>
            </div>

            <div class="card-row">
                <!-- card for configuring Quiz-->
                <div class="card half-card">
                    <h4>⚙ Configure Your Exam</h4>

                    <form action="/mocktest/createorder" method="POST">
                        <input type="hidden" name="examcode" value="<%= prepareTestObj.examcode %>">
                        <input type="hidden" name="subjectcode" value="<%= prepareTestObj.subjectcode %>">

                        <label>Unit</label>
                        <div class="custom-dropdown" id="unitWrapper">
                            <div class="dropdown-selected">Select Unit</div>
                            <div class="dropdown-menu">
                                <input type="text" class="dropdown-search" placeholder="Search unit...">
                                <div class="dropdown-options"></div>
                            </div>
                        </div>
                        <input type="hidden" name="unitcode" id="unitHidden" required>

                        <label>Topic</label>
                        <div class="custom-dropdown disabled" id="topicWrapper">
                            <div class="dropdown-selected">Select Topic</div>
                            <div class="dropdown-menu">
                                <input type="text" class="dropdown-search" placeholder="Search topic...">
                                <div class="dropdown-options"></div>
                            </div>
                        </div>
                        <input type="hidden" name="topiccode" id="topicHidden" required>

                        <div class="inline-row">
                            <div class="inline-group">
                                <label>No. of Questions</label>
                                <select name="count">
                                    <option value="10">10</option>
                                    <option value="20">20</option>
                                    <option value="30">30</option>
                                </select>
                            </div>

                            <div class="inline-group">
                                <label>Difficulty</label>
                                <select name="difficulty">
                                    <option value="easy">Easy</option>
                                    <option value="hard">Hard</option>
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="btn-primary">Proceed to Payment</button>
                        <p id="formError" style="color:red; display:none; font-size:13px;"></p>
                    </form>
                </div>
                <!-- card for Performance Dashboard-->
                <div class="card half-card">
                    <h4>📈 Performance Dashboard
                        <div class="performance-dashboard-card">
                            <select id="scoreType">
                                <option value="accuracy">Accuracy</option>
                                <option value="percentage">Percentage</option>
                            </select>
                            <canvas id="performanceChart" width="800" height="400"></canvas>
                        </div>
                    </h4>
                </div>
            </div>
        </section>
        <%- include('../../partials/desktop/footer') %>
            <script>
                // Script for validating unit,topic,count,difficulty before submit
                const form = document.querySelector("form");
                form.addEventListener("submit", function (e) {
                    const errorBox = document.getElementById("formError");
                    const unit = document.getElementById("unitHidden").value;
                    const topic = document.getElementById("topicHidden").value;
                    const count = document.querySelector("select[name='count']").value;
                    const difficulty = document.querySelector("select[name='difficulty']").value;

                    if (!unit || !topic || !count || !difficulty) {
                        e.preventDefault();
                        errorBox.style.display = "block";
                        errorBox.textContent = "Please complete all fields before proceeding.";
                        return;
                    }

                    errorBox.style.display = "none";

                });
            </script>

            <script>
                //script for filling unit,topic dropdowns
                const examcode = "<%= prepareTestObj.examcode %>";
                const subjectcode = "<%= prepareTestObj.subjectcode %>";

                function truncate(text, max = 40) {
                    return text.length > max ? text.substring(0, max) + "..." : text;
                }

                function setupDropdown(wrapperId, hiddenInputId) {
                    const wrapper = document.getElementById(wrapperId);
                    const selected = wrapper.querySelector(".dropdown-selected");
                    const optionsContainer = wrapper.querySelector(".dropdown-options");
                    const searchInput = wrapper.querySelector(".dropdown-search");
                    const hiddenInput = document.getElementById(hiddenInputId);

                    selected.addEventListener("click", () => {
                        if (wrapper.classList.contains("disabled")) return;
                        wrapper.classList.toggle("active");
                    });

                    document.addEventListener("click", e => {
                        if (!wrapper.contains(e.target)) {
                            wrapper.classList.remove("active");
                        }
                    });

                    searchInput.addEventListener("input", () => {
                        const filter = searchInput.value.toLowerCase();
                        [...optionsContainer.children].forEach(opt => {
                            opt.style.display = opt.textContent.toLowerCase().includes(filter) ? "block" : "none";
                        });
                    });

                    return {
                        setOptions(data, labelKey, valueKey) {
                            optionsContainer.innerHTML = "";
                            data.forEach(item => {
                                const div = document.createElement("div");
                                div.className = "dropdown-option";
                                div.textContent = truncate(item[labelKey]);
                                div.title = item[labelKey];

                                div.onclick = () => {
                                    selected.textContent = truncate(item[labelKey]);
                                    selected.title = item[labelKey];
                                    hiddenInput.value = item[valueKey];
                                    wrapper.classList.remove("active");
                                };

                                optionsContainer.appendChild(div);
                            });
                        },
                        enable() { wrapper.classList.remove("disabled"); },
                        disable() { wrapper.classList.add("disabled"); }
                    };
                }

                const unitDropdown = setupDropdown("unitWrapper", "unitHidden");
                const topicDropdown = setupDropdown("topicWrapper", "topicHidden");

                window.addEventListener("DOMContentLoaded", async () => {
                    const res = await fetch(`/units/${examcode}/${subjectcode}`);
                    const units = await res.json();
                    unitDropdown.setOptions(units, "unitname", "unitcode");
                });

                document.getElementById("unitWrapper")
                    .querySelector(".dropdown-options")
                    .addEventListener("click", async () => {
                        const unitcode = document.getElementById("unitHidden").value;
                        if (!unitcode) return;

                        topicDropdown.enable();
                        const res = await fetch(`/topics/${examcode}/${subjectcode}/${unitcode}`);
                        const topics = await res.json();
                        topicDropdown.setOptions(topics, "topicname", "topiccode");
                    });
            </script>

            <script>
                document.addEventListener("DOMContentLoaded", function () {
<% if (prepareTestObj.resultsforgraph && prepareTestObj.resultsforgraph.length > 1) { %>

  const n = <%= prepareTestObj.resultsforgraph.length %>;
                        const labels = Array.from({ length: n }, (_, i) => "Attempt " + (i + 1));
                        const xValues = Array.from({ length: n }, (_, i) => i + 1);

                        // Accuracy data
                        const accuracyData = [<% prepareTestObj.resultsforgraph.forEach(function (r, index) { %>
    <%= Math.round(Number(r.accuracy)) %><%= index < prepareTestObj.resultsforgraph.length - 1 ? "," : "" %>
  <% }) %>];

                        // Percentage data (replace with your real percentage if available)
                        const percentageData = [<% prepareTestObj.resultsforgraph.forEach(function (r, index) { %>
    <%= Math.round(Number(r.percentage)) %><%= index < prepareTestObj.resultsforgraph.length - 1 ? "," : "" %>
  <% }) %>];

                        let chart = null;

                        function renderPerformanceChart(dataArray, typeName) {
                            // Calculate statistics
                            const mean = Math.round(dataArray.reduce((a, b) => a + b, 0) / n);
                            const stdDev = Math.round(Math.sqrt(dataArray.map(x => Math.pow(x - mean, 2)).reduce((a, b) => a + b, 0) / n));

                            // Moving average (5)
                            const movingAverage = dataArray.map((_, i, arr) => {
                                const start = Math.max(0, i - 4);
                                const subset = arr.slice(start, i + 1);
                                return Math.round(subset.reduce((a, b) => a + b, 0) / subset.length);
                            });

                            // Cumulative Average
                            let cumulativeSum = 0;
                            const cumulativeAvg = dataArray.map((val, i) => {
                                cumulativeSum += val;
                                return Math.round(cumulativeSum / (i + 1));
                            });

                            // Linear Regression
                            const sumX = xValues.reduce((a, b) => a + b, 0);
                            const sumY = dataArray.reduce((a, b) => a + b, 0);
                            const sumXY = xValues.reduce((sum, x, i) => sum + x * dataArray[i], 0);
                            const sumX2 = xValues.reduce((sum, x) => sum + x * x, 0);
                            let slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
                            let intercept = (sumY - slope * sumX) / n;
                            const predictedScore = Math.round(Math.max(0, Math.min(100, slope * (n + 1) + intercept)));
                            const regressionLine = xValues.map(x => Math.round(slope * x + intercept));
                            regressionLine.push(predictedScore);

                            // Extend labels for Predicted
                            const chartLabels = [...labels, "Predicted"];

                            // Best/Worst
                            const maxValue = Math.max(...dataArray);
                            const minValue = Math.min(...dataArray);
                            const bestIndex = dataArray.indexOf(maxValue);
                            const worstIndex = dataArray.indexOf(minValue);
                            const bestPoint = dataArray.map((v, i) => i === bestIndex ? v : null);
                            const worstPoint = dataArray.map((v, i) => i === worstIndex ? v : null);

                            // Destroy existing chart
                            if (chart) chart.destroy();

                            const ctx = document.getElementById("performanceChart").getContext("2d");
                            const gradient = ctx.createLinearGradient(0, 0, 0, 400);
                            gradient.addColorStop(0, "rgba(0,123,255,0.4)");
                            gradient.addColorStop(1, "rgba(0,123,255,0.05)");

                            chart = new Chart(ctx, {
                                type: "line",
                                data: {
                                    labels: chartLabels,
                                    datasets: [
                                        { label: typeName, data: dataArray, borderColor: "#1f77ff", backgroundColor: gradient, tension: 0.4, fill: true, borderWidth: 3 },
                                        { label: "Cumulative Average", data: cumulativeAvg, borderColor: "#00b894", borderWidth: 2, tension: 0.4, fill: false },
                                        { label: "Moving Avg (5)", data: movingAverage, borderColor: "#ff9f43", borderDash: [6, 6], borderWidth: 2, fill: false },
                                        { label: "Trend Line", data: regressionLine, borderColor: "#6c5ce7", borderDash: [4, 4], borderWidth: 2, fill: false, tension: 0 },
                                        { label: "Predicted Next Score", data: [...Array(n).fill(null), predictedScore], borderColor: "#e84393", backgroundColor: "#e84393", pointRadius: 9, pointHoverRadius: 11, showLine: false },
                                        { label: "Overall Average", data: Array(n + 1).fill(mean), borderColor: "#00cec9", borderDash: [3, 3], borderWidth: 2, fill: false },
                                        { label: "Mean + 1σ", data: Array(n + 1).fill(mean + stdDev), borderColor: "#ff6b6b", borderDash: [2, 2], borderWidth: 1.5, fill: false },
                                        { label: "Mean - 1σ", data: Array(n + 1).fill(mean - stdDev), borderColor: "#636e72", borderDash: [2, 2], borderWidth: 1.5, fill: false },
                                        { label: "Best Attempt", data: bestPoint, borderColor: "#f1c40f", pointBackgroundColor: "#f1c40f", pointRadius: 9, pointHoverRadius: 11, showLine: false },
                                        { label: "Worst Attempt", data: worstPoint, borderColor: "#b71540", pointBackgroundColor: "#b71540", pointRadius: 9, pointHoverRadius: 11, showLine: false }
                                    ]
                                },
                                options: {
                                    responsive: true,
                                    animation: { duration: 1600, easing: "easeInOutQuart" },
                                    plugins: {
                                        legend: {
                                            position: "top",
                                            onClick: (e, legendItem, legend) => {
                                                const index = legendItem.datasetIndex;
                                                const ci = legend.chart;
                                                const meta = ci.getDatasetMeta(index);
                                                meta.hidden = meta.hidden === null ? !ci.data.datasets[index].hidden : null;
                                                ci.update();
                                            }
                                        },
                                        tooltip: {
                                            callbacks: {
                                                footer: function () { return "Mean: " + mean + " | Std Dev: " + stdDev + " | Predicted: " + predictedScore + "%"; }
                                            }
                                        }
                                    },
                                    scales: {
                                        y: { min: 0, max: 100, title: { display: true, text: typeName + " (%)" } },
                                        x: { title: { display: true, text: "Attempt Number" } }
                                    }
                                }
                            });
                        }

                        // Initial render with Accuracy
                        renderPerformanceChart(accuracyData, "Accuracy %");

                        // Dropdown event
                        document.getElementById("scoreType").addEventListener("change", function (e) {
                            const val = e.target.value;
                            if (val === "accuracy") {
                                renderPerformanceChart(accuracyData, "Accuracy %");
                            } else {
                                renderPerformanceChart(percentageData, "Percentage %");
                            }
                        });

<% } %>
});
            </script>
</body>

</html>