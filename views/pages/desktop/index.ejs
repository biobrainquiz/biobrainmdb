<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BioBrain - Home</title>
    <link rel="stylesheet" href="/css/desktopStyle.css" />

</head>

<body>
    <%- include('../../partials/desktop/header') %>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-overlay"></div>
            <h2>Master Life Sciences with Smart Quizzes</h2>
            <p>Challenge yourself with quizzes in Zoology, Botany, Genetics, Ecology & More.</p>
            <div>
                <button class="btn-primary" >Start Quiz</button>
                <button class="btn-secondary">View Leaderboard</button>
            </div>
        </section>

        <!-- Quiz Categories -->
        <section class="section">
            <h3>Quiz Categories</h3>
            <div class="card-container">
                <div class="card">
                    <h4>NEET</h4>
                    <p>Zoology</p>
                    <button onclick="startQuiz('E1','S1')">Start</button>
                </div>
                <div class="card">
                    <h4>DL/JL/Asst. Prof.</h4>
                    <p>Zoology</p>
                    <button onclick="startQuiz('E2','S1')">Start</button>
                </div>
                <div class="card">
                    <h4>CSIR.NET/SLET/SET</h4>
                    <p>Life Sciences</p>
                    <button onclick="startQuiz('E3','S2')">Start</button>
                </div>
                <div class="card">
                    <h4>GATE</h4>
                    <p>Zoology</p>
                    <button onclick="startQuiz('E4','S1')">Start</button>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="section">
            <h3>Why Choose BioBrain?</h3>
            <div class="features">
                <div class="feature-box">✔ 1000+ MCQs across topics</div>
                <div class="feature-box">✔ Instant Results & Explanations</div>
                <div class="feature-box">✔ Track Your Progress</div>
                <div class="feature-box">✔ Compete on Leaderboard</div>
            </div>
        </section>

        <!-- Leaderboard Section -->
        <section class="leaderboard">
            <h3>🏆 Top Biology Minds</h3>
            <ul>
                <li>1️⃣ Ananya – 980 Points</li>
                <li>2️⃣ Rahul – 920 Points</li>
                <li>3️⃣ Sneha – 890 Points</li>
                <li>4️⃣ Arjun – 850 Points</li>
                <li>5️⃣ Meera – 830 Points</li>
            </ul>
        </section>
        <script>
            function startQuiz(examcode, subjectcode) {
                window.location.href = `/quiz/prepare/${examcode}/${subjectcode}`;
            }
        </script>
        </script>
        <%- include('../../partials/desktop/footer') %>
</body>

</html>